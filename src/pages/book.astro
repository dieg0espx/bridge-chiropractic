---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book Now" description="Schedule your appointment at The Bridge Chiropractic in San Diego.">
  <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: var(--space-4xl);">
    <div>
      <h1 class="display-3">Book Your Visit</h1>
      <p style="color: var(--color-gray-dark); margin-top: var(--space-lg); margin-bottom: var(--space-xl);">Schedule your appointment online in just a few clicks.</p>
      <a href="#" class="btn btn--primary btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Now</a>
    </div>
  </section>
</Layout>
