---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import VideoBackground from '../../components/VideoBackground.astro';
---

<Layout
  title="Home Exercise Programs San Diego | Personalized Rehab & Strengthening"
  description="Customized home exercise programs in San Diego to support your chiropractic care. Dr. Nate Beyerl creates personalized exercises to maintain progress, prevent re-injury, and build lasting strength."
>
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <video class="hero-fullbleed__video" autoplay muted loop playsinline aria-hidden="true">
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Home Exercises</span>
      <h1 class="hero-fullbleed__title">Simple exercises.<br />Stronger results.</h1>
      <p class="hero-fullbleed__subtitle">Personalized movement programs designed to reinforce your progress between visits and build lasting resilience.</p>
      <div class="hero-fullbleed__cta"><a href="/contact" class="btn btn--primary btn--lg">Book a Visit</a></div>
    </div>
  </section>

  <!-- Overview Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="narrow">
    <div class="service-overview" data-animate="fade-up">
      <span class="section__eyebrow">Why Home Exercises Matter</span>
      <h2 class="display-3">Movement Is Medicine</h2>

      <div class="overview-content">
        <p class="text-large">Home exercises aren't extra credit—they're a critical part of sustainable improvement. What you do between visits determines how well adjustments hold, how quickly you recover, and whether issues return.</p>

        <p>At The Bridge Chiropractic, you won't receive generic handouts or exercises copied from the internet. Every movement is selected specifically for your body, your condition, and your goals. Dr. Nate Beyerl teaches you exactly what to do, why it matters, and how to perform each exercise correctly.</p>

        <p>These programs focus on strengthening weak areas, improving mobility in restricted joints, correcting movement patterns that contribute to pain, and building the resilience you need to stay active long-term.</p>

        <p>You'll learn exercises you can do at home with minimal or no equipment, designed to fit into your daily routine. The goal isn't to turn you into an athlete—it's to give you the tools to maintain function and prevent future problems independently.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Program Components -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">What's Included</span>
      <h2 class="display-3">Components of Your Program</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Targeted exercises addressing your specific needs.</p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="150">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <h3>Strengthening Exercises</h3>
        <p>Target weak muscles that contribute to poor posture, instability, and pain to build long-term support.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="300">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M16 12H8M12 8v8"></path>
          </svg>
        </div>
        <h3>Mobility Work</h3>
        <p>Restore and maintain range of motion in stiff joints and tight tissues to move better daily.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="450">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
          </svg>
        </div>
        <h3>Stability Training</h3>
        <p>Improve balance, coordination, and body awareness to reduce fall risk and enhance control.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="600">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Functional Movement</h3>
        <p>Practice movements that mimic daily activities to improve how you bend, lift, reach, and rotate.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="750">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </div>
        <h3>Postural Correction</h3>
        <p>Address imbalances that cause strain, especially for desk workers and sedentary lifestyles.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="900">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Injury Prevention</h3>
        <p>Build resilience to avoid re-injury and reduce the likelihood of future problems.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- How It Works -->
  <SectionWrapper background="white" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">The Process</span>
      <h2 class="display-3">How Your Program Is Created</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Customized to your body, your goals, and your lifestyle.</p>
    </div>

    <div class="process-steps">
      <div class="process-step" data-animate="fade-up" data-animate-delay="150">
        <div class="process-step__number">1</div>
        <div class="process-step__content">
          <h3>Assessment of Weaknesses</h3>
          <p>Dr. Beyerl identifies which muscles aren't activating properly, where mobility is limited, and what movement patterns need correction based on your examination and treatment response.</p>
        </div>
      </div>

      <div class="process-step" data-animate="scale" data-animate-delay="300">
        <div class="process-step__number">2</div>
        <div class="process-step__content">
          <h3>Exercise Selection</h3>
          <p>Exercises are chosen to address your specific deficits—not generic protocols. Each movement has a purpose tied directly to improving your condition and preventing recurrence.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="450">
        <div class="process-step__number">3</div>
        <div class="process-step__content">
          <h3>Hands-On Instruction</h3>
          <p>You'll be taught proper form in the office. Dr. Beyerl demonstrates each exercise, watches you perform it, and corrects technique to ensure you're doing it correctly at home.</p>
        </div>
      </div>

      <div class="process-step" data-animate="scale" data-animate-delay="600">
        <div class="process-step__number">4</div>
        <div class="process-step__content">
          <h3>Ongoing Modification</h3>
          <p>Your program evolves as you improve. Exercises are progressed, adjusted, or replaced based on your response and changing needs to keep you moving forward.</p>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Benefits -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Why This Works</span>
      <h2 class="display-3">Benefits of Home Exercise Programs</h2>
    </div>

    <ul class="conditions-list" data-animate="fade-up">
      <li><strong>Faster Recovery</strong> — Active participation accelerates healing and reduces treatment time</li>
      <li><strong>Better Adjustment Results</strong> — Stronger muscles help joints stay aligned longer</li>
      <li><strong>Long-Term Independence</strong> — Learn to manage your own health instead of relying solely on treatment</li>
      <li><strong>Reduced Re-Injury Risk</strong> — Build resilience to prevent problems from coming back</li>
      <li><strong>Improved Daily Function</strong> — Move better in activities that matter most to you</li>
      <li><strong>Enhanced Confidence</strong> — Feel capable and in control of your physical health</li>
    </ul>
  </SectionWrapper>

  <!-- FAQ Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Common Questions</span>
      <h2 class="display-3">Home Exercise Program FAQs</h2>
    </div>

    <div class="faq-grid">
      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Do I really need to do exercises at home?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          If your goal is short-term relief, maybe not. But if you want lasting improvement and fewer recurrences, yes—home exercises make a significant difference. They reinforce what's done in the office, strengthen weak areas, and give you control over your own recovery.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          How long do exercises take each day?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Most programs take 10-15 minutes per day. They're designed to fit into your routine, not dominate it. Consistency matters more than duration—doing them regularly is what creates results.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          What if I don't have equipment?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Most exercises require minimal or no equipment—bodyweight movements, resistance bands, or household items. If something specific is needed, recommendations will be made for affordable options or alternatives you already have.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          What if the exercises hurt?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Some discomfort during exercise is normal, especially when working weakened or tight areas. But sharp pain or worsening symptoms means stop and notify Dr. Beyerl. The program will be adjusted to match your current tolerance.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Can I do these forever?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes—many exercises become part of your routine long-term to maintain function and prevent problems. As your condition improves, the program evolves. Some exercises may be phased out, others continued indefinitely depending on your goals.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Will I get written instructions?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes. You'll receive clear instructions with images or videos demonstrating each exercise so you can reference them at home. If something is unclear, bring it up at your next visit for clarification.
        </div>
      </details>
    </div>
  </SectionWrapper>

  <!-- Related Services -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Complementary Care</span>
      <h2 class="display-3">Services That Work Well Together</h2>
    </div>

    <div class="related-services">
      <a href="/services/chiropractic-adjustments" class="related-service-card glass" data-animate="fade-up" data-animate-delay="150">
        <h3>Chiropractic Adjustments</h3>
        <p>Restore joint mobility to move better</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/soft-tissue-therapy" class="related-service-card glass" data-animate="scale" data-animate-delay="300">
        <h3>Soft Tissue Therapy</h3>
        <p>Release restrictions before strengthening</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/fall-prevention-balance-training" class="related-service-card glass" data-animate="fade-up" data-animate-delay="450">
        <h3>Fall Prevention & Balance Training</h3>
        <p>Improve stability and coordination</p>
        <span class="related-service-arrow">→</span>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">
        Take Control of Your Recovery
      </h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">
        Learn personalized exercises designed to support your treatment and build lasting strength.
      </p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Book a Visit</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">
          Call (858) 277-7500
        </a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  .service-overview {
    text-align: center;
  }

  .overview-content {
    margin-top: var(--space-2xl);
    text-align: left;
  }

  .overview-content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
    margin-bottom: var(--space-xl);
  }

  .overview-content .text-large {
    font-size: 1.25rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-2xl);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
    margin-top: var(--space-4xl);
  }

  .benefit-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    border-top: 4px solid var(--color-accent);
    background: var(--color-white);
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .benefit-card:nth-child(3n+1) {
    border-top-color: var(--color-primary);
  }

  .benefit-card:nth-child(3n+2) {
    box-shadow: 0 6px 30px rgba(184, 149, 106, 0.12);
  }

  .benefit-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 12px 48px rgba(184, 149, 106, 0.2);
  }

  .benefit-icon {
    width: 64px;
    height: 64px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .benefit-card:nth-child(3n+1) .benefit-icon {
    background: var(--color-primary);
  }

  .benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .benefit-icon svg {
    stroke: white;
  }

  .benefit-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
    font-weight: 700;
  }

  .benefit-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
    margin: 0;
    font-weight: 400;
  }

  .process-steps {
    display: grid;
    gap: var(--space-2xl);
    max-width: 900px;
    margin: var(--space-4xl) auto 0;
  }

  .process-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .process-step__number {
    width: 80px;
    height: 80px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(71, 128, 184, 0.3);
  }

  .process-step__content h3 {
    font-size: 1.75rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .process-step__content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .conditions-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4xl);
    columns: 2;
    column-gap: var(--space-2xl);
  }

  .conditions-list li {
    padding: var(--space-sm) 0;
    padding-left: var(--space-lg);
    position: relative;
    color: var(--color-gray-dark);
    font-size: 1.0625rem;
    line-height: 1.7;
    break-inside: avoid;
  }

  .conditions-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .conditions-list li strong {
    color: var(--color-charcoal);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-4xl);
  }

  .faq-item {
    background: white;
    border-radius: var(--radius-lg);
    padding: 0 var(--space-lg);
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .faq-summary {
    font-size: 1.125rem;
    font-weight: 600;
    padding: var(--space-lg) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-charcoal);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--color-primary);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-content {
    padding: 0 0 var(--space-lg) 0;
    color: var(--color-gray-dark);
    line-height: 1.8;
  }

  .related-services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .related-service-card {
    position: relative;
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .related-service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
  }

  .related-service-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .related-service-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .related-service-arrow {
    display: inline-block;
    font-size: 1.5rem;
    color: var(--color-primary);
    transition: transform 0.3s ease;
  }

  .related-service-card:hover .related-service-arrow {
    transform: translateX(8px);
  }

  @media (max-width: 1024px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .conditions-list {
      columns: 1;
    }

    .process-step {
      grid-template-columns: 60px 1fr;
      gap: var(--space-md);
    }

    .process-step__number {
      width: 60px;
      height: 60px;
      font-size: 1.5rem;
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }

    .related-services {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '-80px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
