---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import VideoBackground from '../../components/VideoBackground.astro';
---

<Layout
  title="Soft Tissue Therapy San Diego | Myofascial Release & Trigger Point Treatment"
  description="Expert soft tissue therapy in San Diego to reduce muscle tension, improve mobility, and accelerate recovery. Dr. Nate Beyerl uses myofascial release, trigger point therapy, and instrument-assisted techniques."
>
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>

    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Soft Tissue Therapy</span>
      <h1 class="hero-fullbleed__title">Releasing tension<br />your body's been holding.</h1>
      <p class="hero-fullbleed__subtitle">Targeted muscle and fascia work to reduce stiffness, improve range of motion, and help adjustments last longer.</p>
      <div class="hero-fullbleed__cta"><a href="/contact" class="btn btn--primary btn--lg">Book Your Visit</a></div>
    </div>
  </section>

  <!-- Overview Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="narrow">
    <div class="service-overview" data-animate="fade-up">
      <span class="section__eyebrow">What Is Soft Tissue Therapy?</span>
      <h2 class="display-3">Address Muscles, Fascia, and Connective Tissue</h2>

      <div class="overview-content">
        <p class="text-large">Soft tissue therapy targets the muscles, tendons, ligaments, and fascia that support your spine and joints. When these tissues become tight, restricted, or develop adhesions, they limit mobility and contribute to pain—even when joints are moving properly.</p>

        <p>At The Bridge Chiropractic, soft tissue work complements chiropractic adjustments to address the full picture of your musculoskeletal health. Tight muscles pull on joints, restrict movement, and make adjustments less effective if not addressed.</p>

        <p>Dr. Nate Beyerl uses evidence-based techniques including myofascial release, trigger point therapy, instrument-assisted soft tissue mobilization (IASTM), and manual muscle therapy to reduce tension, improve circulation, and accelerate healing.</p>

        <p>This isn't massage for relaxation—it's therapeutic work designed to restore function, break down scar tissue, and help your body move the way it should.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Techniques Section -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Treatment Methods</span>
      <h2 class="display-3">Soft Tissue Techniques We Use</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Evidence-based methods tailored to your specific tissue restrictions.</p>
    </div>

    <div class="techniques-grid">
      <div class="technique-card glass" data-animate="fade-up" data-animate-delay="150">
        <h3>Myofascial Release</h3>
        <p>Sustained pressure applied to fascial restrictions to release tension and restore mobility in connective tissue throughout the body.</p>
      </div>

      <div class="technique-card glass" data-animate="scale" data-animate-delay="300">
        <h3>Trigger Point Therapy</h3>
        <p>Targeted pressure to deactivate painful muscle knots (trigger points) that refer pain to other areas and limit range of motion.</p>
      </div>

      <div class="technique-card glass" data-animate="fade-up" data-animate-delay="450">
        <h3>Instrument-Assisted Mobilization</h3>
        <p>Precision tools detect and treat soft tissue restrictions, break down scar tissue, and improve tissue quality more effectively than hands alone.</p>
      </div>

      <div class="technique-card glass" data-animate="scale" data-animate-delay="600">
        <h3>Manual Muscle Therapy</h3>
        <p>Hands-on techniques to address muscle imbalances, reduce spasm, and restore proper muscle activation patterns.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Benefits Section -->
  <SectionWrapper background="white" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Benefits</span>
      <h2 class="display-3">Why Soft Tissue Therapy Matters</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Addressing muscles and fascia creates lasting improvements in mobility and pain.</p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="150">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
        <h3>Reduced Muscle Tension</h3>
        <p>Release chronic tightness and spasm that limits movement and creates discomfort.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="300">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </div>
        <h3>Improved Flexibility</h3>
        <p>Restore range of motion by addressing restrictions in muscles and connective tissue.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="450">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h3>Faster Recovery</h3>
        <p>Accelerate healing from injuries by improving circulation and breaking down scar tissue.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="600">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </div>
        <h3>Better Adjustment Results</h3>
        <p>Relaxed muscles allow adjustments to hold longer and work more effectively.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="750">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
            <line x1="6" y1="1" x2="6" y2="4"></line>
            <line x1="10" y1="1" x2="10" y2="4"></line>
            <line x1="14" y1="1" x2="14" y2="4"></line>
          </svg>
        </div>
        <h3>Scar Tissue Breakdown</h3>
        <p>Break up adhesions and old scar tissue that limit mobility and cause pain.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="900">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Enhanced Circulation</h3>
        <p>Increase blood flow to tissues to promote healing and reduce inflammation.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Conditions Section -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Conditions Treated</span>
      <h2 class="display-3">Issues Helped by Soft Tissue Therapy</h2>
    </div>

    <ul class="conditions-list" data-animate="fade-up">
      <li><strong>Chronic Muscle Tension</strong> — Persistent tightness in neck, shoulders, back, and hips</li>
      <li><strong>Sports Injuries</strong> — Strains, overuse injuries, and muscle tears</li>
      <li><strong>Repetitive Strain Injuries</strong> — Tennis elbow, golfer's elbow, carpal tunnel syndrome</li>
      <li><strong>Trigger Points</strong> — Painful muscle knots causing referred pain</li>
      <li><strong>Limited Range of Motion</strong> — Stiffness preventing full movement in joints</li>
      <li><strong>Post-Surgical Scar Tissue</strong> — Adhesions limiting function after surgery</li>
      <li><strong>Plantar Fasciitis</strong> — Heel and foot pain from fascial restriction</li>
      <li><strong>IT Band Syndrome</strong> — Lateral knee and hip pain from tight iliotibial band</li>
    </ul>
  </SectionWrapper>

  <!-- FAQ Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Common Questions</span>
      <h2 class="display-3">Soft Tissue Therapy FAQs</h2>
    </div>

    <div class="faq-grid">
      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Does soft tissue therapy hurt?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          It can be temporarily uncomfortable when working on tight or restricted areas, but it should never be unbearable. Pressure is adjusted to your tolerance, and most patients describe it as "good pain"—discomfort that feels productive. Soreness may occur for 24-48 hours after treatment as tissues heal.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          How is this different from massage?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Soft tissue therapy is targeted treatment designed to address specific dysfunctions, break down adhesions, and restore proper tissue quality. While massage focuses on relaxation and general tension, therapeutic soft tissue work is deeper, more precise, and intended to create structural changes that improve function.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          How many sessions will I need?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          That depends on the severity and chronicity of the tissue restriction. Acute issues may improve in 2-4 sessions, while chronic restrictions or old scar tissue may require more consistent work over several weeks. Response is reassessed regularly to determine if the approach is working.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Can soft tissue therapy help with old injuries?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes. Even injuries from years ago can leave scar tissue and adhesions that limit mobility. Techniques like instrument-assisted mobilization are particularly effective at breaking down old, dense scar tissue and restoring tissue quality.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Should I combine this with adjustments?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          In most cases, yes. Tight muscles pull joints out of alignment, making adjustments less effective if soft tissue isn't addressed. Combining both creates better, longer-lasting results by addressing the full musculoskeletal system.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          What should I do after treatment?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Stay hydrated, move gently, and avoid intense activity for 24 hours. Light stretching and gentle movement help tissues heal properly. Ice may reduce soreness if needed, but some post-treatment soreness is normal and indicates the tissue is responding.
        </div>
      </details>
    </div>
  </SectionWrapper>

  <!-- Related Services -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Complementary Care</span>
      <h2 class="display-3">Services That Work Well Together</h2>
    </div>

    <div class="related-services">
      <a href="/services/chiropractic-adjustments" class="related-service-card glass" data-animate="fade-up" data-animate-delay="150">
        <h3>Chiropractic Adjustments</h3>
        <p>Restore joint mobility and alignment</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/home-exercise-programs" class="related-service-card glass" data-animate="scale" data-animate-delay="300">
        <h3>Home Exercise Programs</h3>
        <p>Strengthen and maintain tissue improvements</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/mobility-movement-guidance" class="related-service-card glass" data-animate="fade-up" data-animate-delay="450">
        <h3>Mobility & Movement Guidance</h3>
        <p>Learn to move better and prevent re-injury</p>
        <span class="related-service-arrow">→</span>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">
        Release Tension, Restore Mobility
      </h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">
        Experience targeted soft tissue therapy designed to address the root cause of muscle restriction.
      </p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Book a Visit</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">
          Call (858) 277-7500
        </a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Reuse styles from chiropractic-adjustments.astro */
  .hero-service {
    position: relative;
    height: 75vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-service .container {
    position: relative;
    z-index: 10;
  }

  .hero-service__video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }

  .hero-service__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }

  .hero-service__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 800px;
    padding: 0 var(--space-lg);
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    padding: 10px 24px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    border-radius: 50px;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
  }

  .hero-service__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    margin-bottom: var(--space-lg);
    line-height: 1.1;
    color: white;
  }

  .hero-service__subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    margin-bottom: var(--space-2xl);
    opacity: 0.95;
    line-height: 1.6;
    color: white;
  }

  .hero-service__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--secondary {
    background: transparent;
    border: 2px solid white;
    color: white;
  }

  .btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .service-overview {
    text-align: center;
  }

  .overview-content {
    margin-top: var(--space-2xl);
    text-align: left;
  }

  .overview-content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
    margin-bottom: var(--space-xl);
  }

  .overview-content .text-large {
    font-size: 1.25rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-2xl);
  }

  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .technique-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    transition: all 0.3s ease;
  }

  .technique-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
  }

  .technique-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .technique-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-2xl);
    margin-top: var(--space-4xl);
  }

  .benefit-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--color-accent);
    background: var(--color-white);
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .benefit-card:nth-child(3n+1) {
    border-left-color: var(--color-primary);
  }

  .benefit-card:nth-child(3n+2) {
    box-shadow: 0 6px 30px rgba(184, 149, 106, 0.12);
  }

  .benefit-card:nth-child(even) {
    margin-top: var(--space-md);
  }

  .benefit-card:first-child,
  .benefit-card:nth-child(4) {
    background: var(--color-white);
    border-left-width: 6px;
    box-shadow: 0 8px 30px rgba(184, 149, 106, 0.15);
  }

  .benefit-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 12px 48px rgba(184, 149, 106, 0.2);
    border-left-width: 6px;
  }

  .benefit-icon {
    width: 64px;
    height: 64px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .benefit-card:nth-child(even) .benefit-icon {
    background: var(--color-primary);
  }

  .benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .benefit-icon svg {
    stroke: white;
  }

  .benefit-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
    font-weight: 700;
  }

  .benefit-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
    margin: 0;
    font-weight: 400;
  }

  .conditions-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4xl);
    columns: 2;
    column-gap: var(--space-2xl);
  }

  .conditions-list li {
    padding: var(--space-sm) 0;
    padding-left: var(--space-lg);
    position: relative;
    color: var(--color-gray-dark);
    font-size: 1.0625rem;
    line-height: 1.7;
    break-inside: avoid;
  }

  .conditions-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .conditions-list li strong {
    color: var(--color-charcoal);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-4xl);
  }

  .faq-item {
    background: white;
    border-radius: var(--radius-lg);
    padding: 0 var(--space-lg);
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .faq-summary {
    font-size: 1.125rem;
    font-weight: 600;
    padding: var(--space-lg) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-charcoal);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--color-primary);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-content {
    padding: 0 0 var(--space-lg) 0;
    color: var(--color-gray-dark);
    line-height: 1.8;
  }

  .related-services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .related-service-card {
    position: relative;
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .related-service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
  }

  .related-service-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
