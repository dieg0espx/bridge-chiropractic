---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import VideoBackground from '../../components/VideoBackground.astro';
---

<Layout
  title="Chiropractic Adjustments San Diego | Gentle & Traditional Techniques"
  description="Expert chiropractic adjustments in San Diego for back pain, neck pain, headaches, and more. Dr. Nate Beyerl offers personalized care with gentle and traditional adjustment techniques tailored to your needs."
>
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>

    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Chiropractic Adjustments</span>
      <h1 class="hero-fullbleed__title">Precise adjustments.<br />Lasting relief.</h1>
      <p class="hero-fullbleed__subtitle">Controlled, personalized spinal adjustments that restore mobility and reduce pain — tailored to your comfort level.</p>
      <div class="hero-fullbleed__cta"><a href="#" class="btn btn--primary btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Your Visit</a></div>
    </div>
  </section>

  <!-- Overview Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="narrow">
    <div class="service-overview" data-animate="fade-up">
      <span class="section__eyebrow">What Are Chiropractic Adjustments?</span>
      <h2 class="display-3">Restore Movement, Reduce Pain, Build Resilience</h2>

      <div class="overview-content">
        <p class="text-large">Chiropractic adjustments are controlled, precise movements applied to spinal joints that aren't moving properly. When joints lose mobility due to injury, poor posture, or daily stress, they create irritation that leads to pain, stiffness, and reduced function.</p>

        <p>At The Bridge Chiropractic, care isn't about forcing your spine into place or creating dramatic popping sounds. It's about restoring the natural movement your body needs to function without irritation.</p>

        <p>Dr. Nate Beyerl tailors every adjustment to how your body responds. Some patients benefit from gentle, low-force techniques. Others respond better to traditional manual adjustments. The approach is matched to your comfort, your goals, and what your body needs—not a one-size-fits-all protocol.</p>

        <p>Every visit focuses on reducing irritation, improving mobility, and building the resilience you need to stay active and independent long term.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Benefits Section -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Benefits</span>
      <h2 class="display-3">How Chiropractic Adjustments Help</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Targeted adjustments address the root cause of discomfort, not just symptoms.</p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="150">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <h3>Pain Relief</h3>
        <p>Reduce back pain, neck pain, headaches, and nerve irritation by addressing misalignments and restoring proper joint function.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="300">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
            <line x1="9" y1="9" x2="9.01" y2="9"></line>
            <line x1="15" y1="9" x2="15.01" y2="9"></line>
          </svg>
        </div>
        <h3>Improved Mobility</h3>
        <p>Restore range of motion in stiff joints and tight muscles, making everyday movements easier and more comfortable.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="450">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Injury Prevention</h3>
        <p>Maintain proper alignment and movement patterns to reduce the risk of future injuries and chronic issues.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="600">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
          </svg>
        </div>
        <h3>Better Posture</h3>
        <p>Address postural imbalances that contribute to discomfort, especially for desk workers and those with sedentary lifestyles.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="750">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Enhanced Performance</h3>
        <p>Optimize movement mechanics for better athletic performance and endurance in activities you love.</p>
      </div>

      <div class="benefit-card glass" data-animate="scale" data-animate-delay="900">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </div>
        <h3>Patient Education</h3>
        <p>Understand why pain happens and what you can do to maintain progress between visits and long-term.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Process Section -->
  <SectionWrapper background="white" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Our Approach</span>
      <h2 class="display-3">What to Expect During Your Adjustment</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Care tailored to your comfort, your body, and your goals.</p>
    </div>

    <div class="process-steps">
      <div class="process-step" data-animate="fade-up" data-animate-delay="100">
        <div class="process-step__number">1</div>
        <div class="process-step__content">
          <h3>Thorough Assessment</h3>
          <p>Every adjustment begins with understanding what's not moving properly. Dr. Beyerl evaluates your posture, range of motion, and areas of restriction to identify where care is needed most.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="200">
        <div class="process-step__number">2</div>
        <div class="process-step__content">
          <h3>Personalized Technique Selection</h3>
          <p>Based on your comfort level and how your body responds, adjustments may be delivered using gentle low-force methods or traditional manual techniques. You're never forced into an approach that doesn't feel right.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="300">
        <div class="process-step__number">3</div>
        <div class="process-step__content">
          <h3>Precise, Controlled Adjustments</h3>
          <p>Adjustments are delivered with precision to restore mobility in restricted joints. Some techniques create an audible release, others do not—what matters is improving movement and reducing irritation.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="400">
        <div class="process-step__number">4</div>
        <div class="process-step__content">
          <h3>Ongoing Reassessment</h3>
          <p>Your body's response guides the plan. If progress stalls or something isn't working, the approach is refined. The goal is sustainable improvement, not temporary relief.</p>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Conditions Treated -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Conditions We Treat</span>
      <h2 class="display-3">Common Issues Helped by Chiropractic Adjustments</h2>
    </div>

    <ul class="conditions-list" data-animate="fade-up">
      <li><strong>Lower Back Pain</strong> — Chronic or acute pain from disc issues, muscle strain, or poor mechanics</li>
      <li><strong>Neck Pain & Stiffness</strong> — Tension from poor posture, whiplash, or restricted cervical movement</li>
      <li><strong>Headaches & Migraines</strong> — Tension headaches and cervicogenic headaches caused by neck issues</li>
      <li><strong>Sciatica & Nerve Pain</strong> — Radiating leg pain from nerve compression or irritation</li>
      <li><strong>Joint Stiffness</strong> — Reduced mobility in shoulders, hips, knees, and other joints</li>
      <li><strong>Posture Problems</strong> — Forward head posture, rounded shoulders, and desk-related strain</li>
      <li><strong>Sports Injuries</strong> — Strains, sprains, and overuse injuries affecting athletic performance</li>
      <li><strong>Auto Accident Injuries</strong> — Whiplash and soft tissue damage from car accidents</li>
    </ul>
  </SectionWrapper>

  <!-- FAQ Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Common Questions</span>
      <h2 class="display-3">Chiropractic Adjustment FAQs</h2>
    </div>

    <div class="faq-grid">
      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Do chiropractic adjustments hurt?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Most adjustments are not painful. Some areas may feel tender if they're already irritated, but care is delivered in a controlled, precise way. The goal is to reduce discomfort, not create it. If something doesn't feel right, the approach is adjusted immediately.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Do I have to be "cracked" to get results?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          No. Effective care is about precision and matching the approach to your body. Some techniques involve a joint release (audible noise), while others are gentle and low force. The goal isn't the noise—it's restoring mobility and reducing irritation. Your comfort and response guide the technique used.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          How many adjustments will I need?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          That depends on your goals, the severity of the issue, and how your body responds. Some people improve quickly, while others benefit from a short structured plan to stabilize progress. You will receive clear recommendations and options so you can decide what feels right for you.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Can adjustments help with arthritis?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Chiropractic cannot reverse arthritis, but it can improve joint mobility, reduce stiffness, and support surrounding muscles. Many patients with arthritis feel better when movement improves and irritation decreases. The goal is to help you stay active and maintain function safely.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Are chiropractic adjustments safe?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes. Chiropractic adjustments are one of the safest drug-free therapies for musculoskeletal conditions. Serious complications are extremely rare. Dr. Beyerl uses evidence-based techniques and tailors care to your specific condition and comfort level.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Will I need adjustments forever?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          No. The goal is not dependency—it's building resilience so you can maintain function independently. Some patients choose ongoing maintenance care to stay ahead of issues, but that's a personal choice, not a requirement.
        </div>
      </details>
    </div>
  </SectionWrapper>

  <!-- Related Services -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Complementary Care</span>
      <h2 class="display-3">Services That Work Well Together</h2>
    </div>

    <div class="related-services">
      <a href="/services/soft-tissue-therapy" class="related-service-card glass" data-animate="fade-up" data-animate-delay="100">
        <h3>Soft Tissue Therapy</h3>
        <p>Reduce muscle tension and improve adjustment results</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/home-exercise-programs" class="related-service-card glass" data-animate="fade-up" data-animate-delay="200">
        <h3>Home Exercise Programs</h3>
        <p>Maintain progress and prevent future issues</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/posture-ergonomic-support" class="related-service-card glass" data-animate="fade-up" data-animate-delay="300">
        <h3>Posture & Ergonomic Support</h3>
        <p>Address underlying postural causes of pain</p>
        <span class="related-service-arrow">→</span>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">
        Ready to Move Better?
      </h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">
        Schedule your first visit and experience personalized chiropractic care designed for lasting results.
      </p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="#" class="btn btn--white btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book a Visit</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">
          Call (858) 277-7500
        </a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Service Overview */
  .service-overview {
    text-align: center;
  }

  .overview-content {
    margin-top: var(--space-2xl);
    text-align: left;
  }

  .overview-content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
    margin-bottom: var(--space-xl);
  }

  .overview-content .text-large {
    font-size: 1.25rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-2xl);
  }

  /* Benefits Grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-2xl);
    margin-top: var(--space-4xl);
  }

  .benefit-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--color-accent);
    background: var(--color-white);
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .benefit-card:nth-child(3n+1) {
    border-left-color: var(--color-primary);
  }

  .benefit-card:nth-child(3n+2) {
    box-shadow: 0 6px 30px rgba(184, 149, 106, 0.12);
  }

  .benefit-card:nth-child(even) {
    margin-top: var(--space-md);
  }

  .benefit-card:first-child,
  .benefit-card:nth-child(4) {
    background: var(--color-white);
    border-left-width: 6px;
    box-shadow: 0 8px 30px rgba(184, 149, 106, 0.15);
  }

  .benefit-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 12px 48px rgba(184, 149, 106, 0.2);
    border-left-width: 6px;
  }

  .benefit-icon {
    width: 64px;
    height: 64px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .benefit-card:nth-child(even) .benefit-icon {
    background: var(--color-primary);
  }

  .benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .benefit-icon svg {
    stroke: white;
  }

  .benefit-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
    font-weight: 700;
  }

  .benefit-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
    margin: 0;
    font-weight: 400;
  }

  /* Process Steps */
  .process-steps {
    display: grid;
    gap: var(--space-2xl);
    max-width: 900px;
    margin: var(--space-4xl) auto 0;
  }

  .process-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .process-step__number {
    width: 80px;
    height: 80px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(71, 128, 184, 0.3);
  }

  .process-step__content h3 {
    font-size: 1.75rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .process-step__content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  /* Conditions List */
  .conditions-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4xl);
    columns: 2;
    column-gap: var(--space-2xl);
  }

  .conditions-list li {
    padding: var(--space-sm) 0;
    padding-left: var(--space-lg);
    position: relative;
    color: var(--color-gray-dark);
    font-size: 1.0625rem;
    line-height: 1.7;
    break-inside: avoid;
  }

  .conditions-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .conditions-list li strong {
    color: var(--color-charcoal);
  }

  /* FAQ Grid */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-4xl);
  }

  .faq-item {
    background: white;
    border-radius: var(--radius-lg);
    padding: 0 var(--space-lg);
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .faq-summary {
    font-size: 1.125rem;
    font-weight: 600;
    padding: var(--space-lg) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-charcoal);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--color-primary);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-content {
    padding: 0 0 var(--space-lg) 0;
    color: var(--color-gray-dark);
    line-height: 1.8;
  }

  /* Related Services */
  .related-services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .related-service-card {
    position: relative;
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .related-service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
  }

  .related-service-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .related-service-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .related-service-arrow {
    display: inline-block;
    font-size: 1.5rem;
    color: var(--color-primary);
    transition: transform 0.3s ease;
  }

  .related-service-card:hover .related-service-arrow {
    transform: translateX(8px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .process-step {
      grid-template-columns: 60px 1fr;
      gap: var(--space-md);
    }

    .process-step__number {
      width: 60px;
      height: 60px;
      font-size: 1.5rem;
    }

    .conditions-list {
      columns: 1;
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }

    .related-services {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Scroll-triggered animations
  const observerOptions = {
    root: null,
    rootMargin: '-80px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
