---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import VideoBackground from '../../components/VideoBackground.astro';
---

<Layout
  title="Fall Prevention & Balance Training San Diego | Reduce Fall Risk for Seniors"
  description="Specialized fall prevention and balance training in San Diego for active adults 55+. Dr. Nate Beyerl helps improve stability, coordination, and confidence to reduce fall risk and maintain independence."
>
  <!-- Hero Section -->
  <section class="hero-service">
    <div class="hero-service__overlay"></div>
    <video
      class="hero-service__video"
      autoplay
      muted
      loop
      playsinline
      poster="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1920&h=1080&fit=crop"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1772135494/A_0004C207H251212_163548YT_CANON_kfbpge.mp4" type="video/mp4" />
    </video>
    <div class="container" data-animate="fade-up">
      <div class="hero-service__content">
        <span class="hero-badge">Specialized Care</span>
        <h1 class="hero-service__title">Fall Prevention & Balance Training</h1>
        <p class="hero-service__subtitle">Improve stability, reduce fall risk, and maintain independence with targeted balance and coordination training.</p>
        <div class="hero-service__actions">
          <a href="/contact" class="btn btn--white btn--lg">Book an Appointment</a>
          <a href="tel:8582777500" class="btn btn--secondary btn--lg">Call (858) 277-7500</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <SectionWrapper background="white" spacing="hero" containerWidth="narrow">
    <div class="service-overview" data-animate="fade-up">
      <span class="section__eyebrow">Why Fall Prevention Matters</span>
      <h2 class="display-2">Stay Active, Confident, and Independent</h2>

      <div class="overview-content">
        <p class="text-large">Falls are not a normal part of aging—they're often preventable. Poor balance, reduced coordination, and declining strength create risk, but targeted training can reverse these changes and restore confidence in your movement.</p>

        <p>At The Bridge Chiropractic, fall prevention isn't about wrapping you in bubble wrap or telling you to stop being active. It's about identifying WHY balance is declining and addressing the root causes through evidence-based training.</p>

        <p>Dr. Nate Beyerl uses specialized neurological testing to assess your balance system, identify deficits, and create a personalized program that improves stability, coordination, and proprioception—your body's ability to sense where it is in space.</p>

        <p>This service is particularly valuable for adults over 55, those who have experienced falls or near-falls, anyone with dizziness or balance concerns, and active adults who want to stay mobile and independent as they age.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Program Components -->
  <SectionWrapper background="gray" spacing="hero">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Training Components</span>
      <h2 class="display-2">What Fall Prevention Training Includes</h2>
      <p class="text-large" style="max-width: 700px; margin: 0 auto;">Evidence-based protocols targeting all aspects of balance.</p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="100">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
        </div>
        <h3>Vestibular Training</h3>
        <p>Exercises targeting the inner ear balance system to improve stability and reduce dizziness.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="200">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </div>
        <h3>Visual Coordination</h3>
        <p>Training eye-tracking and visual input to help your brain process spatial information accurately.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="300">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Proprioceptive Exercises</h3>
        <p>Improve your body's awareness of position and movement in space through targeted drills.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="400">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </div>
        <h3>Strength & Stability</h3>
        <p>Build leg, core, and hip strength to support better balance and reduce fall risk.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="500">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h3>Gait Training</h3>
        <p>Improve walking patterns, foot placement, and stride mechanics to move more safely.</p>
      </div>

      <div class="benefit-card glass" data-animate="fade-up" data-animate-delay="600">
        <div class="benefit-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Reaction Training</h3>
        <p>Enhance your ability to respond quickly to unexpected shifts or obstacles.</p>
      </div>
    </div>
  </SectionWrapper>

  <!-- Benefits -->
  <SectionWrapper background="white" spacing="hero">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Expected Outcomes</span>
      <h2 class="display-2">Benefits of Fall Prevention Training</h2>
    </div>

    <div class="conditions-grid">
      <div class="condition-item" data-animate="fade-up" data-animate-delay="100">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Reduced Fall Risk</h4>
          <p>Measurable improvement in balance and stability reduces likelihood of falls</p>
        </div>
      </div>

      <div class="condition-item" data-animate="fade-up" data-animate-delay="150">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Greater Confidence</h4>
          <p>Feel secure in your movement without fear of falling</p>
        </div>
      </div>

      <div class="condition-item" data-animate="fade-up" data-animate-delay="200">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Improved Mobility</h4>
          <p>Move more freely without relying on assistive devices</p>
        </div>
      </div>

      <div class="condition-item" data-animate="fade-up" data-animate-delay="250">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Maintained Independence</h4>
          <p>Continue living actively without fear limiting your activities</p>
        </div>
      </div>

      <div class="condition-item" data-animate="fade-up" data-animate-delay="300">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Better Coordination</h4>
          <p>Enhanced ability to control body movements smoothly</p>
        </div>
      </div>

      <div class="condition-item" data-animate="fade-up" data-animate-delay="350">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <div>
          <h4>Reduced Dizziness</h4>
          <p>Vestibular training helps manage vertigo and balance-related dizziness</p>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Who Benefits -->
  <SectionWrapper background="gray" spacing="hero">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Ideal Candidates</span>
      <h2 class="display-2">Who Benefits from Fall Prevention Training?</h2>
    </div>

    <div class="process-steps">
      <div class="process-step" data-animate="fade-up" data-animate-delay="100">
        <div class="process-step__number">55+</div>
        <div class="process-step__content">
          <h3>Active Adults Over 55</h3>
          <p>Balance naturally declines with age, but it doesn't have to limit you. Training helps maintain stability and prevent age-related balance loss before it becomes a problem.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="200">
        <div class="process-step__number">⚠️</div>
        <div class="process-step__content">
          <h3>Those with Fall History</h3>
          <p>If you've experienced a fall or multiple near-falls, training identifies why it happened and addresses the underlying cause to prevent recurrence.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="300">
        <div class="process-step__number">🌀</div>
        <div class="process-step__content">
          <h3>People with Dizziness</h3>
          <p>Vestibular issues, vertigo, or unexplained dizziness can be addressed with specific balance and coordination exercises designed to retrain the inner ear system.</p>
        </div>
      </div>

      <div class="process-step" data-animate="fade-up" data-animate-delay="400">
        <div class="process-step__number">🎯</div>
        <div class="process-step__content">
          <h3>Proactive Health-Focused Individuals</h3>
          <p>You don't need to have fallen to benefit. Proactive training builds resilience and prevents problems before they start, especially if balance feels "off."</p>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- FAQ Section -->
  <SectionWrapper background="white" spacing="hero" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Common Questions</span>
      <h2 class="display-2">Fall Prevention FAQs</h2>
    </div>

    <div class="faq-grid">
      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          How long does it take to see improvement?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Many people notice improvements in confidence and stability within 4-6 weeks of consistent training. Measurable changes in balance testing often appear within 8-12 weeks. The timeline depends on baseline function and consistency with exercises.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Will this help with dizziness?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes—if dizziness is related to vestibular dysfunction (inner ear), specific exercises can significantly reduce or eliminate symptoms. Other causes of dizziness (cardiovascular, medication-related, neurological) may require medical evaluation.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Is this only for people who have fallen?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          No. Proactive training is valuable even if you haven't fallen. If balance feels "off," you feel unsteady, or you want to prevent future problems, training builds resilience before issues worsen.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          What if I already use a walker or cane?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          That's okay. Training can be adapted to your current level, even if you use assistive devices. The goal is improvement from where you are now—not perfection. Some patients reduce reliance on assistive devices as stability improves.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Do I need special equipment?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Most exercises can be done at home with minimal equipment—a sturdy chair, wall, or countertop for support. Some advanced exercises may use balance pads or foam, but these are optional and affordable if recommended.
        </div>
      </details>

      <details class="faq-item" data-animate="fade-up">
        <summary class="faq-summary">
          Can this help with vertigo?
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="faq-content">
          Yes. Certain types of vertigo, particularly BPPV (benign paroxysmal positional vertigo), respond very well to specific vestibular maneuvers and exercises. Other causes may require medical evaluation, but vestibular training is often part of the solution.
        </div>
      </details>
    </div>
  </SectionWrapper>

  <!-- Related Services -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Complementary Care</span>
      <h2 class="display-2">Services That Work Well Together</h2>
    </div>

    <div class="related-services">
      <a href="/services/home-exercise-programs" class="related-service-card glass" data-animate="fade-up" data-animate-delay="100">
        <h3>Home Exercise Programs</h3>
        <p>Continue balance training at home</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/optimal-longevity-function" class="related-service-card glass" data-animate="fade-up" data-animate-delay="200">
        <h3>Optimal Longevity & Function</h3>
        <p>Preserve mobility and independence long-term</p>
        <span class="related-service-arrow">→</span>
      </a>

      <a href="/services/chiropractic-adjustments" class="related-service-card glass" data-animate="fade-up" data-animate-delay="300">
        <h3>Chiropractic Adjustments</h3>
        <p>Improve joint mobility and posture</p>
        <span class="related-service-arrow">→</span>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-2" style="color: var(--color-white); margin-bottom: var(--space-lg);">
        Move with Confidence Again
      </h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">
        Reduce fall risk and maintain your independence with personalized balance training.
      </p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Start Your Training</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">
          Call (858) 277-7500
        </a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Reuse comprehensive styles */
  .hero-service {
    position: relative;
    height: 75vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-service__video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }

  .hero-service__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.4));
    z-index: 1;
  }

  .hero-service__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 800px;
    padding: 0 var(--space-lg);
  }

  .hero-badge {
    display: inline-block;
    padding: 10px 24px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    border-radius: 50px;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .hero-service__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .hero-service__subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    margin-bottom: var(--space-2xl);
    opacity: 0.95;
    line-height: 1.6;
  }

  .hero-service__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--secondary {
    background: transparent;
    border: 2px solid white;
    color: white;
  }

  .btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .service-overview {
    text-align: center;
  }

  .overview-content {
    margin-top: var(--space-2xl);
    text-align: left;
  }

  .overview-content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
    margin-bottom: var(--space-xl);
  }

  .overview-content .text-large {
    font-size: 1.25rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-2xl);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .benefit-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    text-align: center;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
  }

  .benefit-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
  }

  .benefit-icon svg {
    stroke: white;
  }

  .benefit-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .benefit-card p {
    color: var(--color-gray-dark);
    line-height: 1.7;
  }

  .process-steps {
    display: grid;
    gap: var(--space-2xl);
    max-width: 900px;
    margin: var(--space-4xl) auto 0;
  }

  .process-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .process-step__number {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(71, 128, 184, 0.3);
  }

  .process-step__content h3 {
    font-size: 1.75rem;
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .process-step__content p {
    color: var(--color-gray-dark);
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-4xl);
  }

  .condition-item {
    display: flex;
    align-items: start;
    gap: var(--space-md);
    padding: var(--space-xl);
    background: white;
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-primary);
    transition: all 0.3s ease;
  }

  .condition-item:hover {
    transform: translateX(8px);
