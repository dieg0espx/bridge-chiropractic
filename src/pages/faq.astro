---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="FAQ" description="Frequently asked questions about chiropractic care at The Bridge Chiropractic. Learn about first visits, treatment approaches, insurance, and more.">
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1772135510/A_0004C206H251212_163500CS_CANON_puvlaw.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Questions & Answers</span>
      <h1 class="hero-fullbleed__title">Good questions<br />deserve clear answers.</h1>
      <p class="hero-fullbleed__subtitle">Everything you need to know about chiropractic care, what to expect, and how we can help.</p>
      <div class="hero-fullbleed__cta">
        <a href="/contact" class="btn btn--primary btn--lg">Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Category Navigation -->
  <SectionWrapper spacing="compact">
    <nav class="faq-nav" data-animate="fade-up">
      <a href="#first-visit" class="faq-nav__pill">First Visit</a>
      <a href="#treatment" class="faq-nav__pill">Treatment</a>
      <a href="#neuro" class="faq-nav__pill">Neuro Rehab</a>
      <a href="#practical" class="faq-nav__pill">Practical Info</a>
    </nav>
  </SectionWrapper>

  <!-- First Visit -->
  <SectionWrapper spacing="normal">
    <div class="faq-section" id="first-visit" data-animate="fade-up">
      <div class="faq-section__header">
        <span class="faq-section__label">Getting Started</span>
        <h2 class="faq-section__title">Your First Visit</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What should I expect during my first visit?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Your first visit includes a comprehensive consultation, examination, and discussion of your health history. We take time to understand your concerns, explain what's happening in your body, and discuss treatment options. Expect to spend about 45-60 minutes with us. You won't be rushed through a standardized protocol—your care plan will be created based on YOUR specific needs and goals.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What should I wear to my appointment?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Wear comfortable, loose-fitting clothing that allows for movement. Athletic wear is ideal, but anything you can move comfortably in works fine. For women, it's helpful to wear or bring a sports bra for your initial examination.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Do I need to bring anything to my first appointment?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Please bring your insurance card (if using insurance), a photo ID, and any relevant medical records or imaging (X-rays, MRIs) if you have them. If another doctor referred you, bring the referral documentation. Most importantly, come prepared to discuss your health history and current concerns in detail.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Will I receive treatment on my first visit?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>In most cases, yes. After your consultation and examination, if we determine chiropractic care is appropriate for your condition, we'll typically begin gentle treatment during your first visit. However, we never pressure patients—we'll only proceed when you're comfortable and understand the treatment plan.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>How long does the first appointment take?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Your initial consultation typically takes 45-60 minutes. This includes time for your health history review, physical examination, discussion of findings, and initial treatment if appropriate. We don't rush—this time is dedicated entirely to understanding your needs and starting your care properly.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Should I arrive early for my first visit?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Yes, please arrive 10-15 minutes early for your first visit to complete any necessary paperwork. If you'd prefer, we can email forms to you in advance so you can complete them at home. This helps us maximize your time with Dr. Beyerl during the appointment.</p>
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- About Treatment -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="faq-section" id="treatment" data-animate="fade-up">
      <div class="faq-section__header">
        <span class="faq-section__label">Care & Approach</span>
        <h2 class="faq-section__title">About Treatment</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Is chiropractic care safe?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Yes, chiropractic care is very safe when performed by a licensed professional. Dr. Beyerl uses gentle techniques and adjusts his approach based on each patient's comfort level, age, and health needs. We offer both traditional and low-force adjustment options, so even patients who are nervous about "cracking" can receive effective care.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Does chiropractic treatment hurt?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Most patients find chiropractic treatment comfortable or even relaxing. You may feel some pressure during adjustments, but it shouldn't be painful. If you're sensitive or nervous, we use gentler techniques. Some patients experience mild soreness after their first few visits, similar to what you might feel after starting a new exercise routine—this typically resolves within 24-48 hours.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>How many visits will I need?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>This varies significantly based on your condition, goals, and how your body responds. Some patients feel significant relief after just a few visits, while others benefit from ongoing wellness care. We'll discuss a recommended treatment plan during your first visit, but we don't believe in creating unnecessary dependency. Our goal is to give you the tools to manage your own health long-term.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What conditions do you treat?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We treat a wide range of musculoskeletal conditions including back pain, neck pain, headaches, sciatica, joint pain, and postural issues. We also specialize in neuro rehabilitation for balance issues and fall prevention in adults 55 and older. <a href="/conditions">View our full list of conditions we treat</a>.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What makes your approach different?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We focus on calm, trust-based care that prioritizes your long-term function and independence. Unlike rushed, high-volume practices, we take time to listen, explain, and educate. We emphasize sustainable improvement rather than quick fixes or creating dependency on ongoing adjustments.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What techniques do you use?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We use a variety of evidence-based techniques tailored to each patient, including manual adjustments, soft tissue therapy, movement rehabilitation, and neuro rehabilitation exercises. The techniques we choose depend on your specific condition, comfort level, and treatment goals. We'll always explain what we're doing and why before we begin.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Can I continue my regular activities during treatment?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>In most cases, yes. We encourage staying active during treatment, though we may recommend temporary modifications to certain activities while you heal. Our goal is to help you maintain your lifestyle, not restrict it.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Do you offer exercises or home care recommendations?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Absolutely. Education and empowerment are core to our approach. We'll provide specific exercises, stretches, and self-care strategies to support your recovery and maintain long-term health. These aren't generic handouts—they're tailored to your specific condition and goals.</p>
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Neuro Rehabilitation -->
  <SectionWrapper spacing="normal">
    <div class="faq-section" id="neuro" data-animate="fade-up">
      <div class="faq-section__header">
        <span class="faq-section__label">Specialized Care</span>
        <h2 class="faq-section__title">Neuro Rehabilitation</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What is neuro rehabilitation?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Neuro rehabilitation focuses on improving the connection between your brain and body. It's particularly effective for balance issues, coordination problems, and fall prevention. Using specific exercises and techniques, we help retrain your nervous system to improve stability, reaction time, and overall motor function.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Who benefits from neuro rehabilitation?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Our neuro rehabilitation program is especially beneficial for adults 55 and older who want to maintain independence and reduce fall risk. It's also helpful for anyone experiencing balance issues, dizziness, coordination problems, or concerns about stability.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>How does it reduce fall risk?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Falls often result from a combination of factors: decreased balance, slower reaction times, reduced strength, and poor coordination. Our program addresses all of these through targeted exercises that challenge your vestibular system, improve proprioception, strengthen key muscle groups, and enhance your brain's ability to process movement information quickly.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>How long does neuro rehabilitation take?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Many patients notice improvements in balance and confidence within 4-6 weeks of consistent training. However, like any fitness program, ongoing practice maintains and continues to improve your results. We'll create a personalized program that fits your schedule and needs.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Is it too late to start if I've already had a fall?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Absolutely not. It's never too late to improve your balance and reduce future fall risk. If you've experienced a fall, that's an important signal that intervention can help. We'll start at your current ability level and progress gradually.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Can neuro rehabilitation help with dizziness?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Yes, vestibular rehabilitation—a component of our neuro rehabilitation program—can be very effective for certain types of dizziness, particularly those related to inner ear balance issues. We'll assess your specific type of dizziness and determine if our program is appropriate or if a referral might be better.</p>
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Practical Questions -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="faq-section" id="practical" data-animate="fade-up">
      <div class="faq-section__header">
        <span class="faq-section__label">Logistics</span>
        <h2 class="faq-section__title">Practical Questions</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Do you accept insurance?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We accept most major insurance plans. Coverage varies by plan, so we recommend calling our office or contacting your insurance company to verify your chiropractic benefits. We can also provide documentation for out-of-network reimbursement if needed.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What are your hours?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We're open Monday through Friday, 9am to 5pm. If these hours don't work for you, please contact us—we may be able to arrange an alternative time.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Where are you located?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We're located at 4340 Genesee Ave, Suite 201, San Diego, CA 92117. The office is easily accessible with parking available. <a href="https://maps.google.com/?q=4340+Genesee+Ave+Suite+201+San+Diego+CA+92117" target="_blank" rel="noopener">Get directions on Google Maps</a>.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>How do I schedule an appointment?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>You can schedule by calling <a href="tel:8582777500">(858) 277-7500</a>, emailing <a href="mailto:info@bridgechiropracticsd.com">info@bridgechiropracticsd.com</a>, or using our <a href="/contact">online contact form</a>. We'll confirm your appointment within 24 hours.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What is your cancellation policy?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We ask for at least 24 hours notice if you need to cancel or reschedule. This allows us to offer your time slot to another patient. Late cancellations or no-shows may be subject to a fee.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Is parking available?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Yes, we have convenient parking directly in front of the building. The office is on the second floor, accessible by stairs or elevator.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>What if I need to contact you outside of office hours?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>Email us at info@bridgechiropracticsd.com or use our online contact form—we'll respond the next business day. For urgent health concerns, please contact your primary care physician or visit urgent care.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false">
            <span>Do you offer payment plans?</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-item__answer">
            <p>We accept all major credit cards and can discuss flexible payment options for patients paying out-of-pocket. We're committed to making quality care accessible.</p>
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772139027/fitness-exercise-and-running-woman-at-beach-for-2025-12-17-11-33-16-utc_htkq3f.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2>Still Have Questions?</h2>
      <p>We're happy to answer any questions about our practice, your condition, or whether chiropractic care might be right for you.</p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Contact Us</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Category Navigation */
  .faq-nav {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .faq-nav__pill {
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-charcoal);
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .faq-nav__pill:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }

  /* FAQ Sections */
  .faq-section {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-section__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .faq-section__label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .faq-section__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--color-primary);
    margin: 0;
  }

  /* FAQ List — clean single column */
  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .faq-item__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: 22px 0;
    background: transparent;
    border: none;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-charcoal);
    cursor: pointer;
    text-align: left;
    transition: color 0.2s ease;
  }

  .faq-item__question:hover {
    color: var(--color-primary);
  }

  .faq-item__question span {
    flex: 1;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--color-accent);
  }

  .faq-item__question[aria-expanded="true"] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    max-height: 0;
    overflow: hidden;
    transition: all 0.3s ease;
    opacity: 0;
  }

  .faq-item.active .faq-item__answer {
    max-height: 600px;
    padding-bottom: 22px;
    opacity: 1;
  }

  .faq-item__answer p {
    margin: 0;
    line-height: 1.75;
    color: var(--color-gray-dark);
    font-size: 0.9375rem;
  }

  .faq-item__answer a {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq-item__answer a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .faq-nav__pill {
      padding: 8px 18px;
      font-size: 0.8125rem;
    }

    .faq-section__title {
      font-size: 1.5rem;
    }

    .faq-item__question {
      padding: 18px 0;
      font-size: 1rem;
      gap: var(--space-md);
    }

    .faq-item.active .faq-item__answer {
      padding-bottom: 18px;
    }
  }

  @media (max-width: 480px) {
    .faq-section__title {
      font-size: 1.375rem;
    }

    .faq-item__question {
      font-size: 0.9375rem;
    }

    .faq-item__answer p {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  // FAQ Accordion
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    const question = item.querySelector('.faq-item__question');

    question?.addEventListener('click', () => {
      const isExpanded = question.getAttribute('aria-expanded') === 'true';

      question.setAttribute('aria-expanded', (!isExpanded).toString());
      item.classList.toggle('active');
    });
  });

  // Smooth scroll for nav pills
  document.querySelectorAll('.faq-nav__pill').forEach(pill => {
    pill.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(pill.getAttribute('href')!);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Scroll-triggered animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, { root: null, rootMargin: '-100px', threshold: 0.1 });

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
