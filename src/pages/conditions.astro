---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Conditions We Treat" description="The Bridge Chiropractic treats back pain, neck pain, sciatica, headaches, balance issues, and more. Dr. Nathan Beyerl offers personalized care in San Diego.">
  <!-- Hero -->
  <section class="hero-fullbleed">
    <img src="/images/chiropractic-care.jpg" class="hero-fullbleed__image" alt="" aria-hidden="true" />
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Conditions We Treat</span>
      <h1 class="hero-fullbleed__title">Pain doesn't have to<br />run your life.</h1>
      <p class="hero-fullbleed__subtitle">Whether it's back pain, neck stiffness, headaches, or balance issues, we find what's driving the problem and build a plan to fix it.</p>
      <div class="hero-fullbleed__cta">
        <a href="#" class="btn btn--primary btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Spinal Conditions -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Spinal Health</span>
      <h2 class="display-3">Back & Neck Conditions</h2>
    </div>

    <ul class="conditions-list mt-4xl" data-animate="fade-up">
      <li><strong>Low Back Pain</strong> — Whether from injury, poor posture, or degenerative changes, we address the root cause through adjustments, soft tissue work, and movement training.</li>
      <li><strong>Neck Pain & Stiffness</strong> — Office work, phone use, and daily stress create chronic neck tension. We restore mobility and reduce pain through gentle, targeted care.</li>
      <li><strong>Sciatica</strong> — Radiating leg pain from nerve compression requires precise treatment. We identify the source and provide relief through comprehensive care.</li>
      <li><strong>Disc Problems</strong> — Herniated, bulging, or degenerative discs benefit from gentle decompression and stabilization exercises tailored to your condition.</li>
      <li><strong>Spinal Stenosis</strong> — Narrowing of the spinal canal causes pain and numbness. We help manage symptoms and improve function through conservative care.</li>
      <li><strong>Scoliosis</strong> — Adult scoliosis can cause discomfort and imbalance. We provide supportive care to reduce pain and improve spinal function.</li>
    </ul>
  </SectionWrapper>

  <!-- Joint & Extremity -->
  <SectionWrapper spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Joint Health</span>
      <h2 class="display-3">Joint & Extremity Conditions</h2>
    </div>

    <div class="joint-grid mt-4xl">
      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Shoulder Pain</h3>
        <p class="joint-card__desc">Rotator cuff issues, frozen shoulder, and impingement affect daily activities. We address both the joint and surrounding soft tissue.</p>
        <ul class="joint-card__list">
          <li>Rotator cuff injuries</li>
          <li>Frozen shoulder</li>
          <li>Impingement syndrome</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Hip & Knee Pain</h3>
        <p class="joint-card__desc">Joint pain in the lower body affects mobility and independence. We help restore function and reduce discomfort.</p>
        <ul class="joint-card__list">
          <li>Hip arthritis & bursitis</li>
          <li>Knee osteoarthritis</li>
          <li>IT band syndrome</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Elbow & Wrist Issues</h3>
        <p class="joint-card__desc">Repetitive strain and overuse injuries respond well to targeted chiropractic care and rehabilitation.</p>
        <ul class="joint-card__list">
          <li>Tennis/golfer's elbow</li>
          <li>Carpal tunnel syndrome</li>
          <li>Wrist tendonitis</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Ankle & Foot Pain</h3>
        <p class="joint-card__desc">From plantar fasciitis to ankle sprains, we treat the foundation of your movement system.</p>
        <ul class="joint-card__list">
          <li>Plantar fasciitis</li>
          <li>Ankle instability</li>
          <li>Achilles tendonitis</li>
        </ul>
      </article>
    </div>
  </SectionWrapper>

  <!-- Neurological & Other -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Neurological Health</span>
      <h2 class="display-3">Neurological & Other Conditions</h2>
    </div>

    <ul class="conditions-list mt-4xl" data-animate="fade-up">
      <li><strong>Headaches & Migraines</strong> — Tension and cervicogenic headaches often respond to spinal adjustments and soft tissue therapy.</li>
      <li><strong>Balance & Dizziness</strong> — Vestibular issues and proprioception problems benefit from our specialized neuro rehabilitation.</li>
      <li><strong>Posture Problems</strong> — Forward head posture and rounded shoulders create chronic strain. We help you stand taller and move better.</li>
    </ul>
  </SectionWrapper>

  <!-- CTA -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">Not Sure If We Can Help?</h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">Schedule a consultation to discuss your specific condition and discover if chiropractic care is right for you.</p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="#" class="btn btn--white btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Consultation</a>
        <a href="tel:8582777500" class="btn btn--outline-white btn--lg">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  .mt-4xl {
    margin-top: 64px;
  }

  /* Conditions List */
  .conditions-list {
    list-style: none;
    padding: 0;
    columns: 2;
    column-gap: var(--space-2xl);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .conditions-list li {
    padding: var(--space-sm) 0;
    padding-left: var(--space-lg);
    position: relative;
    color: var(--color-gray-dark);
    font-size: 1.0625rem;
    line-height: 1.7;
    break-inside: avoid;
  }

  .conditions-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .conditions-list li strong {
    color: var(--color-charcoal);
  }

  /* Joint Cards Grid */
  .joint-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .joint-card {
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .joint-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .joint-card__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }

  .joint-card__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-md);
  }

  .joint-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .joint-card__list li {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary);
    background: rgba(58, 114, 100, 0.08);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mt-4xl {
      margin-top: 32px;
    }

    .conditions-list {
      columns: 1;
    }

    .joint-grid {
      grid-template-columns: 1fr;
    }

    .joint-card {
      padding: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .conditions-list li {
      font-size: 0.9375rem;
    }
  }
</style>

<script>
  const observerOptions = { root: null, rootMargin: '-100px', threshold: 0.1 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
