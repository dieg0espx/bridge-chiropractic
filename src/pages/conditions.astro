---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import ContentGrid from '../components/ContentGrid.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Conditions We Treat" description="The Bridge Chiropractic treats back pain, neck pain, sciatica, headaches, balance issues, and more. Dr. Nathan Beyerl offers personalized care in San Diego.">
  <!-- Hero -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Conditions We Treat</span>
      <h1 class="hero-fullbleed__title">Pain doesn't have to<br />run your life.</h1>
      <p class="hero-fullbleed__subtitle">Whether it's back pain, neck stiffness, headaches, or balance issues — we find what's driving the problem and build a plan to fix it.</p>
      <div class="hero-fullbleed__cta">
        <a href="/contact" class="btn btn--primary btn--lg">Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Intro - Premium Approach Section -->
  <SectionWrapper spacing="normal">
    <div class="personalized-care-section">
      <div class="personalized-care-grid">
        <!-- Main Content -->
        <div class="personalized-care-main" data-animate="fade-right">
          <div class="badge-premium">Personalized Approach</div>
          <h2 class="display-2" style="margin-bottom: 20px; line-height: 1.2;">Your Unique Journey to Wellness</h2>
          <p class="text-large" style="color: var(--color-gray-dark); line-height: 1.8; margin-bottom: 32px;">
            Every patient receives individualized care. What works for one person may not work for another—that's why Dr. Beyerl takes time to understand <strong style="color: var(--color-primary);">YOUR</strong> specific condition, goals, and concerns before creating a treatment plan.
          </p>

          <div class="care-features">
            <div class="care-feature-item">
              <div class="care-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
              <div>
                <h4>Comprehensive Assessment</h4>
                <p>Deep dive into your health history and current condition</p>
              </div>
            </div>

            <div class="care-feature-item">
              <div class="care-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <div>
                <h4>Tailored Treatment Plans</h4>
                <p>Custom strategies designed for your specific needs</p>
              </div>
            </div>

            <div class="care-feature-item">
              <div class="care-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                  <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
              </div>
              <div>
                <h4>Ongoing Support</h4>
                <p>Continuous care adjustments as you progress</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats Sidebar -->
        <div class="personalized-care-stats" data-animate="fade-left" data-animate-delay="200">
          <div class="stat-card glass">
            <div class="stat-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <div class="stat-number" data-count="100">100</div>
            <div class="stat-label">Individualized Care Plans</div>
          </div>

          <div class="stat-card glass">
            <div class="stat-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="stat-number" data-count="45">45</div>
            <div class="stat-label">Minute Initial Consultation</div>
          </div>

          <div class="stat-card glass">
            <div class="stat-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              </svg>
            </div>
            <div class="stat-number" data-count="15" data-suffix="+">15</div>
            <div class="stat-label">Years Experience</div>
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  <!-- Spinal Conditions -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Spinal Health</span>
      <h2 class="display-3">Back & Neck Conditions</h2>
    </div>

    <div class="condition-list mt-4xl">
      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Low Back Pain</h3>
          <p class="condition-item__desc">Whether from injury, poor posture, or degenerative changes, we address the root cause through adjustments, soft tissue work, and movement training.</p>
        </div>
      </article>

      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Neck Pain & Stiffness</h3>
          <p class="condition-item__desc">Office work, phone use, and daily stress create chronic neck tension. We restore mobility and reduce pain through gentle, targeted care.</p>
        </div>
      </article>

      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Sciatica</h3>
          <p class="condition-item__desc">Radiating leg pain from nerve compression requires precise treatment. We identify the source and provide relief through comprehensive care.</p>
        </div>
      </article>

      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Disc Problems</h3>
          <p class="condition-item__desc">Herniated, bulging, or degenerative discs benefit from gentle decompression and stabilization exercises tailored to your condition.</p>
        </div>
      </article>

      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Spinal Stenosis</h3>
          <p class="condition-item__desc">Narrowing of the spinal canal causes pain and numbness. We help manage symptoms and improve function through conservative care.</p>
        </div>
      </article>

      <article class="condition-item" data-animate="fade-up">
        <div class="condition-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <div class="condition-item__body">
          <h3 class="condition-item__title">Scoliosis</h3>
          <p class="condition-item__desc">Adult scoliosis can cause discomfort and imbalance. We provide supportive care to reduce pain and improve spinal function.</p>
        </div>
      </article>
    </div>
  </SectionWrapper>

  <!-- Joint & Extremity -->
  <SectionWrapper spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Joint Health</span>
      <h2 class="display-3">Joint & Extremity Conditions</h2>
    </div>

    <div class="joint-grid mt-4xl">
      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Shoulder Pain</h3>
        <p class="joint-card__desc">Rotator cuff issues, frozen shoulder, and impingement affect daily activities. We address both the joint and surrounding soft tissue.</p>
        <ul class="joint-card__list">
          <li>Rotator cuff injuries</li>
          <li>Frozen shoulder</li>
          <li>Impingement syndrome</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Hip & Knee Pain</h3>
        <p class="joint-card__desc">Joint pain in the lower body affects mobility and independence. We help restore function and reduce discomfort.</p>
        <ul class="joint-card__list">
          <li>Hip arthritis & bursitis</li>
          <li>Knee osteoarthritis</li>
          <li>IT band syndrome</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Elbow & Wrist Issues</h3>
        <p class="joint-card__desc">Repetitive strain and overuse injuries respond well to targeted chiropractic care and rehabilitation.</p>
        <ul class="joint-card__list">
          <li>Tennis/golfer's elbow</li>
          <li>Carpal tunnel syndrome</li>
          <li>Wrist tendonitis</li>
        </ul>
      </article>

      <article class="joint-card" data-animate="fade-up">
        <h3 class="joint-card__title">Ankle & Foot Pain</h3>
        <p class="joint-card__desc">From plantar fasciitis to ankle sprains, we treat the foundation of your movement system.</p>
        <ul class="joint-card__list">
          <li>Plantar fasciitis</li>
          <li>Ankle instability</li>
          <li>Achilles tendonitis</li>
        </ul>
      </article>
    </div>
  </SectionWrapper>

  <!-- Neurological & Other -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Neurological Health</span>
      <h2 class="display-3">Neurological & Other Conditions</h2>
    </div>

    <ContentGrid columns={3} gap="xl" class="mt-4xl">
      <div class="glass" style="padding: 40px; border-radius: 16px; text-align: center;">
        <div style="width: 64px; height: 64px; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        </div>
        <h4 style="font-size: 1.25rem; margin-bottom: 12px; font-weight: 600;">Headaches & Migraines</h4>
        <p style="font-size: 0.9375rem; color: var(--color-gray-dark); line-height: 1.6;">Tension and cervicogenic headaches often respond to spinal adjustments and soft tissue therapy.</p>
      </div>

      <div class="glass" style="padding: 40px; border-radius: 16px; text-align: center;">
        <div style="width: 64px; height: 64px; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
        </div>
        <h4 style="font-size: 1.25rem; margin-bottom: 12px; font-weight: 600;">Balance & Dizziness</h4>
        <p style="font-size: 0.9375rem; color: var(--color-gray-dark); line-height: 1.6;">Vestibular issues and proprioception problems benefit from our specialized neuro rehabilitation.</p>
      </div>

      <div class="glass" style="padding: 40px; border-radius: 16px; text-align: center;">
        <div style="width: 64px; height: 64px; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
        </div>
        <h4 style="font-size: 1.25rem; margin-bottom: 12px; font-weight: 600;">Posture Problems</h4>
        <p style="font-size: 0.9375rem; color: var(--color-gray-dark); line-height: 1.6;">Forward head posture and rounded shoulders create chronic strain. We help you stand taller.</p>
      </div>
    </ContentGrid>
  </SectionWrapper>

  <!-- CTA -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2>Not Sure If We Can Help?</h2>
      <p>Schedule a consultation to discuss your specific condition and discover if chiropractic care is right for you.</p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Book Consultation</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  .mt-4xl {
    margin-top: 64px;
  }

  /* Personalized Care Section */
  .personalized-care-section {
    position: relative;
  }

  .personalized-care-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .personalized-care-main {
    position: relative;
  }

  .badge-premium {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(71, 128, 184, 0.12);
    border: 1px solid rgba(71, 128, 184, 0.2);
    border-radius: var(--radius-full);
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .care-features {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .care-feature-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .care-feature-item:hover {
    transform: translateX(8px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    border-color: rgba(71, 128, 184, 0.2);
  }

  .care-feature-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(71, 128, 184, 0.10);
    border-radius: var(--radius-md);
    transition: all 0.3s ease;
  }

  .care-feature-item:hover .care-feature-icon {
    background: var(--color-primary);
  }

  .care-feature-item:hover .care-feature-icon svg {
    stroke: white;
  }

  .care-feature-item h4 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: 6px;
  }

  .care-feature-item p {
    font-size: 0.9375rem;
    color: var(--color-gray-dark);
    line-height: 1.6;
    margin: 0;
  }

  /* Stats Sidebar */
  .personalized-care-stats {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 100px;
  }

  .stat-card {
    padding: 32px;
    border-radius: var(--radius-xl);
    text-align: center;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .stat-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 16px 40px rgba(71, 128, 184, 0.2);
  }

  .stat-icon {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    background: rgba(71, 128, 184, 0.12);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }

  .stat-card:hover .stat-icon {
    background: var(--color-primary);
    transform: rotate(5deg) scale(1.1);
  }

  .stat-card:hover .stat-icon svg {
    stroke: white;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    font-family: var(--font-heading);
    background: var(--color-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9375rem;
    color: var(--color-gray-dark);
    font-weight: 500;
    line-height: 1.4;
  }

  /* Spinal Condition List */
  .condition-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .condition-item {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .condition-item:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .condition-item__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: rgba(58, 114, 100, 0.08);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .condition-item__title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: var(--space-xs);
  }

  .condition-item__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-gray-dark);
  }

  /* Joint Cards Grid */
  .joint-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .joint-card {
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .joint-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .joint-card__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }

  .joint-card__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-md);
  }

  .joint-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .joint-card__list li {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary);
    background: rgba(58, 114, 100, 0.08);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .mt-4xl {
      margin-top: 48px;
    }

    .personalized-care-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .personalized-care-stats {
      position: static;
      flex-direction: row;
      overflow-x: auto;
      gap: 16px;
      padding-bottom: 8px;
    }

    .stat-card {
      min-width: 200px;
      flex-shrink: 0;
    }

    .stat-number {
      font-size: 3rem;
    }
  }

  @media (max-width: 768px) {
    .mt-4xl {
      margin-top: 32px;
    }

    .care-feature-item {
      flex-direction: column;
      gap: 16px;
      padding: 20px;
    }

    .care-feature-icon {
      width: 48px;
      height: 48px;
    }

    .stat-card {
      padding: 24px;
      min-width: 180px;
    }

    .stat-icon {
      width: 60px;
      height: 60px;
      margin-bottom: 16px;
    }

    .stat-number {
      font-size: 2.5rem;
    }

    .stat-label {
      font-size: 0.875rem;
    }

    .condition-list,
    .joint-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .care-feature-item:hover {
      transform: none;
    }

    .personalized-care-stats {
      flex-direction: column;
      gap: 16px;
    }

    .stat-card {
      min-width: 100%;
    }
  }
</style>

<script>
  const observerOptions = { root: null, rootMargin: '-100px', threshold: 0.1 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
