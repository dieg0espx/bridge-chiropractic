---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Blog" description="Health tips, chiropractic insights, and wellness advice from Dr. Nathan Beyerl at The Bridge Chiropractic in San Diego.">
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <img src="/images/care-plan.jpg" class="hero-fullbleed__image" alt="" aria-hidden="true" />
    <div class="hero-fullbleed__overlay"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Health & Wellness</span>
      <h1 class="hero-fullbleed__title">The Bridge Blog</h1>
      <p class="hero-fullbleed__subtitle">Insights, tips, and education to help you move better and live fuller.</p>
    </div>
  </section>

  <!-- Blog Posts -->
  <SectionWrapper background="white" spacing="normal">
    <div class="article-grid">
      <a href="/blog/5-daily-stretches-to-improve-mobility" class="article-card" data-animate="fade-up">
        <div class="article-card__image">
          <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&h=400&fit=crop" alt="Person stretching" loading="lazy" />
        </div>
        <div class="article-card__content">
          <span class="article-card__category">Movement & Exercise</span>
          <h3>5 Daily Stretches to Improve Your Mobility</h3>
          <p>Simple, effective exercises you can do at home to maintain flexibility and reduce stiffness.</p>
          <span class="article-card__meta">March 15, 2026 &middot; 5 min read</span>
        </div>
      </a>

      <a href="/blog/ultimate-guide-to-desk-ergonomics" class="article-card" data-animate="fade-up">
        <div class="article-card__image">
          <img src="https://images.unsplash.com/photo-1593642632559-0c6d3fc62b89?w=600&h=400&fit=crop" alt="Ergonomic desk setup" loading="lazy" />
        </div>
        <div class="article-card__content">
          <span class="article-card__category">Posture & Ergonomics</span>
          <h3>The Ultimate Guide to Desk Ergonomics</h3>
          <p>How to set up your workspace to prevent neck pain, back pain, and repetitive strain injuries.</p>
          <span class="article-card__meta">February 28, 2026 &middot; 7 min read</span>
        </div>
      </a>

      <a href="/blog/balance-exercises-for-adults-55-plus" class="article-card" data-animate="fade-up">
        <div class="article-card__image">
          <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&h=400&fit=crop" alt="Senior doing balance exercise" loading="lazy" />
        </div>
        <div class="article-card__content">
          <span class="article-card__category">Fall Prevention</span>
          <h3>Balance Exercises for Adults 55+</h3>
          <p>Evidence-based exercises to improve stability and reduce fall risk as you age.</p>
          <span class="article-card__meta">February 10, 2026 &middot; 6 min read</span>
        </div>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">Have a Health Question?</h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">Dr. Beyerl is always happy to discuss your health concerns.</p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="#" class="btn btn--white btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book a Visit</a>
        <a href="tel:8582777500" class="btn btn--outline-white btn--lg">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Article Grid */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .article-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
  }

  .article-card__image {
    width: 100%;
    height: 220px;
    background: rgba(71, 128, 184, 0.06);
    overflow: hidden;
  }

  .article-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .article-card:hover .article-card__image img {
    transform: scale(1.05);
  }

  .article-card__content {
    padding: var(--space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .article-card__category {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .article-card h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .article-card p {
    margin: 0;
    color: var(--color-gray-dark);
    line-height: 1.7;
    font-size: 0.9375rem;
    flex: 1;
  }

  .article-card__meta {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-gray-medium);
    margin-top: var(--space-md);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .article-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .article-card__image {
      height: 180px;
    }

    .article-card__content {
      padding: var(--space-lg);
    }
  }
</style>

<script>
  const observerOptions = { root: null, rootMargin: '-80px', threshold: 0.1 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
