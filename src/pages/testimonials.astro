---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import VideoBackground from '../components/VideoBackground.astro';

const GMB_REVIEW_URL = "https://www.google.com/maps?cid=2402560187786235962";
const GMB_PROFILE_URL = "https://www.google.com/maps?cid=2402560187786235962";

interface Review {
  name: string;
  text: string;
  stars: number;
  date: string;
  badge?: string;
}

