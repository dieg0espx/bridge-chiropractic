// GMB stats — update these when syncing
const ratingScore = 4.9;
const totalReviews = 96;
const fullStars = Math.floor(ratingScore);
const hasHalfStar = ratingScore % 1 >= 0.25;
---

<Layout title="Reviews" description="Read what patients say about their experience at The Bridge Chiropractic. Real Google reviews from San Diego patients who found relief through Dr. Nathan Beyerl's care.">
  <!-- Hero -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/so_15/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Google Reviews</span>
      <h1 class="hero-fullbleed__title">Real people.<br />Real results.</h1>
      <p class="hero-fullbleed__subtitle">See why {totalReviews}+ patients rated us {ratingScore} stars on Google.</p>
      <div class="hero-fullbleed__cta">
        <a href={GMB_REVIEW_URL} target="_blank" rel="noopener" class="btn btn--primary btn--lg">Write a Review</a>
        <a href="#" class="btn btn--outline-white btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Google Rating Bar -->
  <div class="rating-bar">
    <div class="rating-bar__inner">
      <a href={GMB_PROFILE_URL} target="_blank" rel="noopener" class="rating-bar__google" aria-label="View on Google">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
        </svg>
      </a>
      <div class="rating-bar__stars">
        {[...Array(fullStars)].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
        {hasHalfStar && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
            <defs>
              <linearGradient id="halfStar">
                <stop offset="50%" stop-color="#F59E0B" />
                <stop offset="50%" stop-color="#D1D5DB" />
              </linearGradient>
            </defs>
            <path fill="url(#halfStar)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        )}
      </div>
      <span class="rating-bar__score">{ratingScore}</span>
      <span class="rating-bar__sep" aria-hidden="true"></span>
      <span class="rating-bar__text">{totalReviews} Google Reviews</span>
      <a href={GMB_REVIEW_URL} target="_blank" rel="noopener" class="rating-bar__link">
        Write a review
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>

  <!-- Reviews Grid -->
  <SectionWrapper spacing="normal" containerWidth="normal">
    <div class="reviews-grid" role="list" aria-label="Patient reviews from Google">
      {reviews.map((review) => (
        <article class="review-card" role="listitem" data-animate="fade-up">
          <div class="review-card__header">
            <div class="review-card__avatar" aria-hidden="true">
              {review.name.charAt(0)}
            </div>
            <div>
              <p class="review-card__author">{review.name}</p>
              <div class="review-card__meta">
                {review.badge && <span class="review-card__badge">{review.badge}</span>}
                <span class="review-card__date">{review.date}</span>
              </div>
            </div>
          </div>
          <div class="review-card__stars" aria-label={`${review.stars} stars`}>
            {[...Array(review.stars)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <blockquote class="review-card__text">"{review.text}"</blockquote>
        </article>
      ))}
    </div>

    <!-- Write a Review CTA -->
    <div class="reviews-cta" data-animate="fade-up">
      <p class="reviews-cta__text">Had a great experience? Share it on Google!</p>
      <a href={GMB_REVIEW_URL} target="_blank" rel="noopener" class="btn btn--primary btn--lg">
        Write a Review
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </SectionWrapper>

  <!-- CTA -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4"
    posterImage="/images/IMG_0954.JPG"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">Ready to feel the difference?</h2>
      <p style="color: rgba(255,255,255,0.85); max-width: 550px; margin: 0 auto var(--space-2xl); line-height: 1.7;">Schedule your first visit and find out what personalized chiropractic care can do for you.</p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
        <a href="#" class="btn btn--white btn--lg" data-cal-link="sdbridgechiropractic/30min" data-cal-config='{"layout":"month_view"}'>Book Your Visit</a>
        <a href="tel:8582777500" class="btn btn--outline-white btn--lg">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Rating Bar */
  .rating-bar {
    background: var(--color-charcoal);
    padding: var(--space-lg) 0;
  }

  .rating-bar__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .rating-bar__google {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .rating-bar__google:hover {
    opacity: 0.8;
  }

  .rating-bar__stars {
    display: flex;
    gap: 2px;
  }

  .rating-bar__score {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .rating-bar__sep {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.2);
  }

  .rating-bar__text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .rating-bar__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-left: var(--space-md);
    transition: gap 0.2s ease;
  }

  .rating-bar__link:hover {
    gap: 10px;
  }

  /* Reviews Masonry Grid */
  .reviews-grid {
    columns: 3;
    column-gap: var(--space-lg);
  }

  .review-card {
    break-inside: avoid;
    margin-bottom: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .review-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .review-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .review-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .review-card__author {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin: 0;
    line-height: 1.3;
  }

  .review-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: 2px;
  }

  .review-card__badge {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-primary);
    background: rgba(58, 114, 100, 0.08);
    padding: 1px 8px;
    border-radius: var(--radius-full);
  }

  .review-card__date {
