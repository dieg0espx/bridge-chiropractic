      <article class="review-card" data-animate="fade-up">
        <div class="review-card__stars" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <blockquote class="review-card__text">"My posture has improved dramatically and my neck pain is gone. Dr. Beyerl explained everything clearly and gave me exercises to do at home. Life-changing!"</blockquote>
        <p class="review-card__author">Lisa R.</p>
        <p class="review-card__tag">Neck Pain</p>
      </article>

      <article class="review-card" data-animate="fade-up">
        <div class="review-card__stars" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
