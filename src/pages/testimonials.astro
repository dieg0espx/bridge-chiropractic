---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Testimonials" description="Read what patients say about their experience at The Bridge Chiropractic. Real reviews from San Diego patients who found relief through Dr. Nathan Beyerl's care.">
  <!-- Hero -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Patient Stories</span>
      <h1 class="hero-fullbleed__title">Real people.<br />Real results.</h1>
      <p class="hero-fullbleed__subtitle">Hear from patients who came in with pain and left with a plan that actually worked.</p>
      <div class="hero-fullbleed__cta">
        <a href="/contact" class="btn btn--primary btn--lg">Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Google Rating Bar -->
  <div class="rating-bar">
    <div class="rating-bar__inner">
      <div class="rating-bar__stars">
        {[...Array(5)].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
      </div>
      <span class="rating-bar__score">5.0</span>
      <span class="rating-bar__sep" aria-hidden="true"></span>
      <span class="rating-bar__text">200+ Google Reviews</span>
      <a href="https://g.page/r/bridgechiropracticsd/review" target="_blank" rel="noopener" class="rating-bar__link">
        Write a review
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>

  <!-- Reviews Grid -->
  <SectionWrapper spacing="normal" containerWidth="normal">
    <div class="reviews-grid">
      <article class="review-card" data-animate="fade-up">
        <div class="review-card__stars" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <blockquote class="review-card__text">"Dr. Beyerl transformed my chronic back pain into a thing of the past. His approach and genuine care made all the difference. I can finally enjoy hiking again!"</blockquote>
        <p class="review-card__author">Sarah M.</p>
        <p class="review-card__tag">Back Pain</p>
      </article>

      <article class="review-card" data-animate="fade-up">
        <div class="review-card__stars" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <blockquote class="review-card__text">"After years of migraines, I finally found relief. The team here truly cares about their patients and it shows in every visit. Highly recommend!"</blockquote>
        <p class="review-card__author">Michael T.</p>
        <p class="review-card__tag">Migraines</p>
      </article>

      <article class="review-card" data-animate="fade-up">
        <div class="review-card__stars" aria-label="5 stars">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <blockquote class="review-card__text">"As an active runner, I need to stay in peak condition. Dr. Beyerl keeps me running strong and injury-free."</blockquote>
        <p class="review-card__author">Jennifer L.</p>
