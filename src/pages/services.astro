---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import OfferingCard from '../components/OfferingCard.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Services" description="Comprehensive chiropractic services including gentle adjustments, soft tissue therapy, movement training, and specialized neuro rehabilitation.">
  <!-- Hero Section -->
  <section class="hero-fullbleed">
    <video
      class="hero-fullbleed__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4" type="video/mp4" />
    </video>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>
    <div class="hero-fullbleed__content">
      <span class="hero-fullbleed__eyebrow">Our Services</span>
      <h1 class="hero-fullbleed__title">Treatment that adapts<br />to your body.</h1>
      <p class="hero-fullbleed__subtitle">Adjustments, soft tissue work, and movement training — combined and tailored to how you respond, so results actually last.</p>
      <div class="hero-fullbleed__cta">
        <a href="/contact" class="btn btn--primary btn--lg">Book Your Visit</a>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <SectionWrapper background="white" spacing="normal" containerWidth="narrow">
    <div style="text-align: center;" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent); display: block; margin-bottom: 20px;">Holistic Approach</span>
      <h2 class="display-2" style="margin-bottom: 24px;">More Than Adjustments</h2>
      <p class="text-large" style="color: var(--color-gray-dark); line-height: 1.8; margin-bottom: 24px;">At The Bridge Chiropractic, we offer comprehensive care that addresses your whole body. Our integrated approach combines multiple techniques to help you move better, feel stronger, and live pain-free.</p>
      <p style="color: var(--color-gray-dark); line-height: 1.8; font-size: 1.0625rem;">Each treatment plan is personalized to your specific condition, goals, and comfort level.</p>
    </div>
  </SectionWrapper>

  <!-- Service Navigation Cards -->
  <SectionWrapper background="gray" spacing="normal">
    <div class="section__header" style="text-align: center; margin-bottom: 64px;" data-animate="fade-up">
      <span class="section__eyebrow" style="color: var(--color-accent);">Explore Our Services</span>
      <h2 class="display-3">Choose Your Path to Wellness</h2>
    </div>

    <div class="service-nav-grid">
      <OfferingCard
        image="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=800&h=600&fit=crop"
        title="Chiropractic Adjustments"
        description="Gentle and traditional adjustment techniques tailored to restore proper function and reduce pain."
        link="/services/chiropractic-adjustments"
        badge="Core Service"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=800&h=600&fit=crop"
        title="Soft Tissue Therapy"
        description="Target tension and adhesions that limit mobility through specialized myofascial techniques."
        link="/services/soft-tissue-therapy"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&h=600&fit=crop"
        title="Home Exercise Programs"
        description="Personalized exercises and stretches designed to reinforce your treatment and prevent future issues."
        link="/services/home-exercise-programs"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&h=600&fit=crop"
        title="Fall Prevention & Balance"
        description="Specialized training to improve balance, coordination, and stability to reduce fall risk."
        link="/services/fall-prevention-balance-training"
        badge="Specialized"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800&h=600&fit=crop"
        title="Mobility & Movement Guidance"
        description="Expert guidance to improve how you move and maintain functional independence."
        link="/services/mobility-movement-guidance"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1549890762-0a3f8933bc76?w=800&h=600&fit=crop"
        title="Optimal Longevity & Function"
        description="Proactive care designed to preserve mobility, strength, and independence as you age."
        link="/services/optimal-longevity-function"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=800&h=600&fit=crop"
        title="Posture & Ergonomic Support"
        description="Correct postural imbalances and optimize your workspace for long-term health."
        link="/services/posture-ergonomic-support"
        glass={true}
      />

      <OfferingCard
        image="https://images.unsplash.com/photo-1559757175-0eb30cd8c063?w=800&h=600&fit=crop"
        title="Neuro & Brain Rehabilitation"
        description="Specialized neurological care for balance, coordination, and cognitive function."
        link="/services/neuro-brain-rehabilitation"
        badge="Specialized"
        glass={true}
      />
    </div>
  </SectionWrapper>

  <!-- CTA Section -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4"
    posterImage="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <span class="section__eyebrow" style="color: rgba(255,255,255,0.9); display: block; margin-bottom: 20px;">Ready to Begin?</span>
      <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 24px;">Experience Personalized Care</h2>
      <p style="font-size: 1.25rem; margin-bottom: 48px; opacity: 0.95;">Schedule your consultation and discover which services are right for you.</p>
      <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn btn--white btn--lg">Book a Visit</a>
        <a href="tel:8582777500" class="btn btn--secondary btn--lg" style="background: transparent; border: 2px solid white; color: white;">Call (858) 277-7500</a>
      </div>
    </div>
  </VideoBackground>
</Layout>

<style>
  /* Service Navigation Grid */
  .service-nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-top: 48px;
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .service-nav-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1025px) {
    .service-nav-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1400px) {
    .service-nav-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .service-nav-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .hero-fullbleed {
      height: 70vh !important;
      min-height: 500px !important;
    }
  }
</style>

<script>
  // Scroll-triggered animations
  const observerOptions = {
    root: null,
    rootMargin: '-100px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

</script>
