---
import Layout from '../layouts/Layout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import ContentGrid from '../components/ContentGrid.astro';
import OfferingCard from '../components/OfferingCard.astro';
import VideoBackground from '../components/VideoBackground.astro';

const homeReviews = [
  { name: "Joshua Stevens", text: "Dr. Nate was PHENOMENAL! I personally have never done anything with chiropractic care so I was a little anxious at first but Dr. Nate explained everything he was going to be doing and made sure that my comfort was priority number one. He created such a warm environment and did great! I highly recommend Dr. Nate for your chiropractic needs!" },
  { name: "Andrew Tierney", text: "I just had an intro assessment with Dr. Nathan Beyerl and he immediately impressed me. He took the time to really understand what was going on with my lower back and explained everything in a clear, straightforward way. The adjustment and treatment he did made an instant difference — walked out feeling noticeably better.", badge: "Local Guide" },
  { name: "Sarah Waddell", text: "I can't say enough good things about Dr. Nathan at Bridge Chiropractic. He is absolutely incredible and truly gifted at what he does. I came to him with a level 2 MCL injury, and thanks to his expertise, care, and guidance, I'm now able to function and go about my daily activities with ease." },
  { name: "Jena Willard", text: "I've seen many different chiropractors over the years, but my first consultation with Nate at Bridge Chiropractic gave me more relief than I've experienced in the last six months combined. Beyond that, he took the time to uncover and explain root issues that no one had ever addressed before." },
  { name: "Stefani Woll", text: "This was my first time visiting a chiropractor and I was a little nervous, but Dr. Nate made sure I felt comfortable with the entire process and walked me through each step. He also personalized my experience exactly to the type of pain I was having! Highly recommend!" },
  { name: "Jonathan Haddad", text: "Dr. Nate is super knowledgeable about holistic health overall, not just chiropractic care, which makes a huge difference. Every adjustment feels really targeted, and I notice relief right away instead of just temporary fixes." },
  { name: "Erick Armenta", text: "This has easily been the best chiropractic experience I have ever had. Dr. Beyerl truly took the time to sit down with me and explain the process as we were going through my session. It's easily recognizable that Dr. Beyerl is a true expert in his career. I will absolutely 100% be back.", badge: "Local Guide" },
  { name: "Mary Fifield", text: "Dr. Nate is the first person to put me on a path toward long term systemic healing, combining adjustments with stretching exercises and eventually strengthening. I highly recommend him.", badge: "Local Guide" },
  { name: "Lauren Werner", text: "Dr. Nate Beyerl is amazing! He helped me with a knee injury I sustained years ago. Within a few minutes of manual adjusting, I was feeling more stable walking on it and less pain. Not to mention his kind and gentle demeanor as he explains what is going on." },
  { name: "Zakary Goodmanson", text: "Most chiropractors just crack your back and send you on your way with a ridiculous bill. Dr. Beyerl listens to the actual problem and solves it at the root. Big thanks for reaffirming my confidence in chiropractors." },
  { name: "Isaiah Strode", text: "Dr. Nate takes care of his patients extremely well and is very knowledgeable in his field. If you want someone who can work with you through any physical issues you have he is the guy to see! 10/10 would recommend!!!" },
  { name: "Katelynn McWeeny", text: "The Bridge Chiropractic is great! Dr. Beyerl took the time to thoroughly understand my concerns and explained the treatment process in a way that made it easy to follow. I especially appreciated how he takes a holistic approach, not just treating symptoms but working to improve my overall well-being." },
];

const starSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`;
const fiveStars = Array(5).fill(starSvg).join('');
---

<Layout title="Bridge Chiropractic - Transform Your Wellness | San Diego">
  <!-- Hero Video Section -->
  <HeroVideo
    posterImage="/images/IMG_0954.JPG"
    ctaText="Book a Visit"
    ctaLink="/contact"
    ctaCalLink="sdbridgechiropractic/30min"
    secondaryCtaText="Learn about our approach"
    secondaryCtaLink="/about"
  />

  <!-- What Sets Us Apart Section -->
  <SectionWrapper id="content" background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">What Makes Us Different</span>
      <h2 class="display-3">Not your typical adjustment</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 600px; margin: 0 auto;">
        Most chiropractors stop at the spine. Dr. Beyerl combines three disciplines in every visit to get you real, lasting results.
      </p>
    </div>

    <div class="steps-timeline mt-4xl">
      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
        </div>
        <div class="step__connector"></div>
        <h3 class="step__title">Chiropractic Adjustments</h3>
        <p class="step__desc">Every adjustment is chosen based on how your body responds, not a preset protocol. Whether it's a traditional manual adjustment or a low-force technique, the goal is restoring the movement your joints have lost.</p>
      </article>

      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        </div>
        <div class="step__connector"></div>
        <h3 class="step__title">Soft Tissue Work</h3>
        <p class="step__desc">Tight muscles pull joints back out of place. That's why every visit includes hands-on soft tissue work, releasing the tension that caused the problem, not just the symptom. It's the reason adjustments actually hold.</p>
      </article>

      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="step__title">Optimizing Biomechanics</h3>
        <p class="step__desc">Pain doesn't happen in a vacuum. It comes from how you move. Dr. Beyerl analyzes your movement patterns and builds a plan to fix the mechanics behind the issue, so you perform better and stay out of the office longer.</p>
      </article>
    </div>
  </SectionWrapper>

  <!-- Featured Services Section -->
  <SectionWrapper background="gray" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Our Services</span>
      <h2 class="display-2">Personalized treatment to create results that last</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 600px; margin: 0 auto;">
        Every service is chosen based on what your body needs — not a one-size-fits-all protocol.
      </p>
    </div>

    <div class="services-grid mt-4xl">
      <a href="/services/chiropractic-adjustments" class="svc-card" data-animate="fade-up">
        <img src="/images/chiropractic-care.jpg" alt="Chiropractic adjustment treatment" class="svc-card__img" loading="lazy" />
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Chiropractic Adjustments</h3>
          <p class="svc-card__desc">Precise adjustments to restore joint movement, reduce irritation, and help your body move better.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/soft-tissue-therapy" class="svc-card" data-animate="fade-up">
        <img src="https://res.cloudinary.com/dku1gnuat/image/upload/v1774906990/softTissue_aos2sb.jpg" alt="Soft tissue therapy session" class="svc-card__img" loading="lazy" />
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Soft Tissue Therapy</h3>
          <p class="svc-card__desc">Reduce muscle tension to decrease stiffness and help adjustments last longer.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/home-exercise-programs" class="svc-card" data-animate="fade-up">
        <img src="https://res.cloudinary.com/dku1gnuat/image/upload/v1774906871/homeExercises_melplr.jpg" alt="Home exercise program" class="svc-card__img" loading="lazy" />
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Home Exercises</h3>
          <p class="svc-card__desc">Personalized exercises to support your progress and build long-term resilience.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/fall-prevention-balance-training" class="svc-card" data-animate="fade-up">
        <img src="https://res.cloudinary.com/dku1gnuat/image/upload/v1774906890/fallPrevention_tdetsh.jpg" alt="Fall prevention balance training" class="svc-card__img" loading="lazy" />
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Fall Prevention</h3>
          <p class="svc-card__desc">Improve balance, coordination, and stability to reduce fall risk and maintain independence.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/optimal-longevity-function" class="svc-card" data-animate="fade-up">
        <img src="https://res.cloudinary.com/dku1gnuat/image/upload/v1774906937/longetivity_scf670.jpg" alt="Optimal longevity and function care" class="svc-card__img" loading="lazy" />
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Optimal Longevity & Function</h3>
          <p class="svc-card__desc">Proactive care designed to preserve mobility, strength, and independence as you age.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/services" class="svc-card svc-card--all" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">All Services</h3>
          <p class="svc-card__desc">Explore our full range of personalized chiropractic and wellness services.</p>
          <span class="svc-card__link">View all <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </SectionWrapper>

  <!-- What We Treat Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Conditions</span>
      <h2 class="display-3">What We Treat</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 700px; margin: 0 auto;">
        From everyday aches to chronic conditions, we provide expert care for a wide range of health concerns.
      </p>
    </div>

    <ul class="conditions-list mt-4xl" data-animate="fade-up">
      <li><strong>Back Pain</strong> — Lower, mid, and upper back relief</li>
      <li><strong>Neck Pain</strong> — Tension, stiffness, and mobility</li>
      <li><strong>Headaches</strong> — Migraines and tension headaches</li>
      <li><strong>Sciatica</strong> — Leg pain and numbness</li>
      <li><strong>Joint Pain</strong> — Shoulders, hips, knees, ankles</li>
      <li><strong>Posture Issues</strong> — Alignment and ergonomics</li>
      <li><strong>Sports Injuries</strong> — Recovery and prevention</li>
      <li><strong>Auto Injuries</strong> — Whiplash and accident recovery</li>
    </ul>

    <div class="text-center mt-4xl" data-animate="fade-up">
      <a href="/conditions" class="btn btn--primary btn--lg">See All Conditions</a>
    </div>
  </SectionWrapper>

  <!-- About Dr. Beyerl Section -->
  <SectionWrapper background="gray" spacing="normal" containerWidth="normal">
    <div class="two-col-premium">
      <div data-animate="fade-right">
        <span class="section__eyebrow">About Dr. Beyerl</span>
        <h2 class="display-3" style="margin-bottom: var(--space-lg);">Helping Active Adults Stay Strong, Mobile, and Independent</h2>
        <p class="text-large" style="color: var(--color-gray-dark); margin-bottom: var(--space-xl);">
          Dr. Nate Beyerl works with active adults in San Diego who want more than short-term relief. His personalized approach helps reduce pain, restore movement, and preserve independence long term.
        </p>

        <ul class="check-list" style="margin-bottom: var(--space-2xl);">
          <li>Treatment tailored to how your body responds</li>
          <li>Soft tissue and movement integration</li>
          <li>Specialized care for adults 55+</li>
          <li>Balance and stability training to reduce fall risk</li>
          <li>Low force or traditional adjustments based on your needs</li>
        </ul>

        <a href="/about" class="btn btn--primary btn--lg">Meet Dr. Beyerl</a>
      </div>

      <div data-animate="fade-left">
        <img
          src="/images/IMG_0954.JPG"
          alt="Dr. Nathan Beyerl"
          style="border-radius: var(--radius-xl); box-shadow: var(--shadow-xl); width: 100%; height: 600px; object-fit: cover; object-position: top center;"
        />
      </div>
    </div>
  </SectionWrapper>

  <!-- Testimonials Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="full">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Testimonials</span>
      <h2 class="display-3">What Our Patients Say</h2>
      <div class="testimonials-rating-bar">
        <div style="display: flex; gap: 4px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="var(--color-star, #F59E0B)">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <span class="testimonials-rating-score">4.9</span>
        <span style="color: var(--color-gray-medium);">•</span>
        <span class="testimonials-rating-label">96 Google Reviews</span>
      </div>
    </div>

    <div class="testimonials-scroll-container mt-4xl" role="region" aria-label="Patient testimonials">
      <div class="testimonials-scroll-track" role="list">
        {[...homeReviews, ...homeReviews].map((review) => (
        <article class="testimonial-card" role="listitem">
          <div style="display: flex; gap: 4px; margin-bottom: var(--space-md); color: var(--color-accent);" set:html={fiveStars} />
          <p style="font-size: 1.0625rem; line-height: 1.7; margin-bottom: var(--space-lg); color: var(--color-charcoal);">
            "{review.text}"
          </p>
          <div style="display: flex; align-items: center; gap: var(--space-sm);">
            <p style="font-weight: 600; color: var(--color-charcoal);">— {review.name}</p>
            {review.badge && <span style="font-size: 0.75rem; color: var(--color-gray-dark); background: var(--color-gray-light, #f3f4f6); padding: 2px 8px; border-radius: 9999px;">{review.badge}</span>}
          </div>
        </article>
        ))}
      </div>
    </div>
  </SectionWrapper>

  <!-- FAQ Preview Section -->
  <SectionWrapper background="gray" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Questions</span>
      <h2 class="display-3">Frequently Asked</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 700px; margin: 0 auto;">
        Get answers to common questions about chiropractic care and our practice.
      </p>
    </div>

    <div class="faq-grid mt-4xl">
      <div class="faq-column">
        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            What should I expect on my first visit?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            Your first visit is about clarity, not pressure. We'll discuss your concerns, perform a detailed movement and mobility assessment, and determine what's contributing to your symptoms. If care is appropriate, adjustments are precise and controlled, tailored to your comfort and response. You'll leave with a clear understanding of what's going on and what the next steps look like, so you can make an informed decision.
          </div>
        </details>

        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            Do adjustments hurt?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            Most adjustments are not painful. Some areas may feel tender if they're already irritated, but care is delivered in a controlled, precise way. The goal is to reduce discomfort, not create it. If something doesn't feel right, we adjust the approach.
          </div>
        </details>

        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            Do I have to be "cracked" to get results?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            No. Effective care is about precision and matching the approach to your body. Some techniques involve a joint release (audible noise), while others are gentle and low force. The goal isn't the noise, but aligning the spine to increase mobility and decrease pain. Your comfort and response guide the technique used.
          </div>
        </details>

        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            How many visits will I need?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            That depends on your goals, the severity of the issue, and how your body responds. Some people improve quickly, while others benefit from a short structured plan to stabilize progress. You will receive clear recommendations and options so you can decide what feels right for you.
          </div>
        </details>
      </div>

      <div class="faq-column">
        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            Do you accept insurance?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            We are an out-of-network provider for most insurance plans. Many policies include out-of-network benefits that may reimburse a portion of your care. We verify your benefits and submit claims on your behalf when applicable so the process is straightforward. For patients with traditional Medicare, covered services are billed directly and Medicare typically pays a portion of the visit, which helps make care more affordable. Our team will review your specific benefits and explain what to expect before you begin.
          </div>
        </details>

        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            What makes your approach different?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            Care is tailored to how your body responds. Instead of using a single technique for everyone, adjustments, soft tissue therapy, and movement training are combined when appropriate to improve results. If something is not progressing as expected, the plan is reassessed and refined. The focus is long-term function, not just temporary relief.
          </div>
        </details>

        <details class="faq-item" data-animate="fade-up">
          <summary class="faq-summary">
            Can chiropractic help if I have arthritis?
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="faq-icon">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-content">
            Chiropractic cannot reverse arthritis, but it can improve joint mobility, reduce stiffness, and support surrounding muscles. Many patients with arthritis feel better when movement improves and irritation decreases. The goal is to help you stay active and maintain function safely.
          </div>
        </details>
      </div>
    </div>

    <div class="text-center mt-3xl" data-animate="fade-up">
      <a href="/faq" class="btn btn--primary btn--lg">View All FAQs</a>
    </div>
  </SectionWrapper>

  <!-- Premium CTA Section with Video Background -->
  <VideoBackground
    videoUrl="https://res.cloudinary.com/dku1gnuat/video/upload/v1772140186/professional-male-chiropractor-physiotherapist-tre-2025-12-17-11-25-49-utc_wkikq4.mov"
    posterImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1920&h=1080&fit=crop"
    overlayOpacity={0.7}
    class="cta-premium"
  >
    <div class="container container-narrow" data-animate="fade-up">
      <h2 class="display-3" style="color: var(--color-white); margin-bottom: var(--space-lg);">
        Ready to Begin Your Wellness Journey?
      </h2>
      <p class="text-large" style="color: rgba(255, 255, 255, 0.9); max-width: 700px; margin: 0 auto var(--space-2xl);">
        Schedule your consultation today and discover what's possible for your health.
      </p>
      <div style="display: flex; gap: var(--space-lg); justify-content: center; flex-wrap: wrap;">
