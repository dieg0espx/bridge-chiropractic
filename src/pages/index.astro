---
import Layout from '../layouts/Layout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import ContentGrid from '../components/ContentGrid.astro';
import OfferingCard from '../components/OfferingCard.astro';
import VideoBackground from '../components/VideoBackground.astro';
---

<Layout title="Bridge Chiropractic - Transform Your Wellness | San Diego">
  <!-- Hero Video Section -->
  <HeroVideo
    posterImage="/images/IMG_0954.JPG"
    ctaText="Book a Visit"
    ctaLink="/contact"
    ctaCalLink="sdbridgechiropractic/30min"
    secondaryCtaText="Learn about our approach"
    secondaryCtaLink="/about"
  />

  <!-- What Sets Us Apart Section -->
  <SectionWrapper id="content" background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Our Approach</span>
      <h2 class="display-3">What sets us apart</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 600px; margin: 0 auto;">
        Three pillars of care, combined and tailored to how your body responds.
      </p>
    </div>

    <div class="steps-timeline mt-4xl">
      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
        </div>
        <div class="step__connector"></div>
        <h3 class="step__title">Chiropractic Adjustments</h3>
        <p class="step__desc">Precise, personalized spinal adjustments that restore joint mobility, reduce nerve irritation, and help your body move the way it's designed to.</p>
      </article>

      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        </div>
        <div class="step__connector"></div>
        <h3 class="step__title">Soft Tissue Work</h3>
        <p class="step__desc">Myofascial release, trigger point therapy, and targeted muscle work to break down tension and adhesions — so adjustments hold longer and you feel better faster.</p>
      </article>

      <article class="step" data-animate="fade-up">
        <div class="step__number">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="step__title">Optimizing Biomechanics</h3>
        <p class="step__desc">Movement pattern analysis, corrective exercises, and performance guidance to build lasting resilience, prevent re-injury, and support longevity.</p>
      </article>
    </div>
  </SectionWrapper>

  <!-- Featured Services Section -->
  <SectionWrapper background="gray" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Our Services</span>
      <h2 class="display-2">Personalized treatment to create results that last</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 600px; margin: 0 auto;">
        Every service is chosen based on what your body needs — not a one-size-fits-all protocol.
      </p>
    </div>

    <div class="services-grid mt-4xl">
      <a href="/services/chiropractic-adjustments" class="svc-card" style="background-image: url('/images/chiropractic-care.jpg');" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Chiropractic Adjustments</h3>
          <p class="svc-card__desc">Precise adjustments to restore joint movement, reduce irritation, and help your body move better.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/soft-tissue-therapy" class="svc-card" style="background-image: url('/images/soft-tissue.jpg');" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Soft Tissue Therapy</h3>
          <p class="svc-card__desc">Reduce muscle tension to decrease stiffness and help adjustments last longer.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/home-exercise-programs" class="svc-card" style="background-image: url('/images/movement-training.jpg');" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Home Exercises</h3>
          <p class="svc-card__desc">Personalized exercises to support your progress and build long-term resilience.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/fall-prevention-balance-training" class="svc-card" style="background-image: url('/images/senior-wellness.jpg');" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Fall Prevention</h3>
          <p class="svc-card__desc">Improve balance, coordination, and stability to reduce fall risk and maintain independence.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>

      <a href="/services/optimal-longevity-function" class="svc-card" style="background-image: url('/images/care-plan.jpg');" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">Optimal Longevity & Function</h3>
          <p class="svc-card__desc">Proactive care designed to preserve mobility, strength, and independence as you age.</p>
          <span class="svc-card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>
      <a href="/services" class="svc-card svc-card--all" data-animate="fade-up">
        <div class="svc-card__overlay"></div>
        <div class="svc-card__content">
          <h3 class="svc-card__title">All Services</h3>
          <p class="svc-card__desc">Explore our full range of personalized chiropractic and wellness services.</p>
          <span class="svc-card__link">View all <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </SectionWrapper>

  <!-- What We Treat Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="normal">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Conditions</span>
      <h2 class="display-3">What We Treat</h2>
      <p class="text-large" style="color: var(--color-gray-dark); max-width: 700px; margin: 0 auto;">
        From everyday aches to chronic conditions, we provide expert care for a wide range of health concerns.
      </p>
    </div>

    <ContentGrid columns={4} gap="lg" class="mt-4xl">
      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 11l3 3L22 4"></path>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Back Pain</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Lower, mid, and upper back relief</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="7"></circle>
            <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Neck Pain</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Tension, stiffness, and mobility</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Headaches</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Migraines and tension headaches</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Sciatica</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Leg pain and numbness</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Joint Pain</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Shoulders, hips, knees, ankles</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 20V10"></path>
            <path d="M12 20V4"></path>
            <path d="M6 20v-6"></path>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Posture Issues</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Alignment and ergonomics</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Sports Injuries</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Recovery and prevention</p>
      </article>

      <article class="glass" style="padding: var(--space-xl); border-radius: var(--radius-lg); text-align: center;">
        <div class="icon-container icon-container--accent mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
          </svg>
        </div>
        <h4 style="font-size: 1.125rem; margin-bottom: var(--space-xs); font-family: var(--font-heading);">Auto Injuries</h4>
        <p style="font-size: 0.9rem; color: var(--color-gray-dark);">Whiplash and accident recovery</p>
      </article>
    </ContentGrid>

    <div class="text-center mt-4xl" data-animate="fade-up">
      <a href="/conditions" class="btn btn--primary btn--lg">See All Conditions</a>
    </div>
  </SectionWrapper>

  <!-- About Dr. Beyerl Section -->
  <SectionWrapper background="gray" spacing="normal" containerWidth="normal">
    <div class="two-col-premium">
      <div data-animate="fade-right">
        <span class="section__eyebrow">About Dr. Beyerl</span>
        <h2 class="display-3" style="margin-bottom: var(--space-lg);">Helping Active Adults Stay Strong, Mobile, and Independent</h2>
        <p class="text-large" style="color: var(--color-gray-dark); margin-bottom: var(--space-xl);">
          Dr. Nate Beyerl works with active adults in San Diego who want more than short-term relief. His personalized approach helps reduce pain, restore movement, and preserve independence long term.
        </p>

        <ul class="check-list" style="margin-bottom: var(--space-2xl);">
          <li>Treatment tailored to how your body responds</li>
          <li>Soft tissue and movement integration</li>
          <li>Specialized care for adults 55+</li>
          <li>Balance and stability training to reduce fall risk</li>
          <li>Low force or traditional adjustments based on your needs</li>
        </ul>

        <a href="/about" class="btn btn--primary btn--lg">Meet Dr. Beyerl</a>
      </div>

      <div data-animate="fade-left">
        <img
          src="/images/IMG_0954.JPG"
          alt="Dr. Nathan Beyerl"
          style="border-radius: var(--radius-xl); box-shadow: var(--shadow-xl); width: 100%; height: 600px; object-fit: cover; object-position: top center;"
        />
      </div>
    </div>
  </SectionWrapper>

  <!-- Testimonials Section -->
  <SectionWrapper background="white" spacing="normal" containerWidth="full">
    <div class="section__header" data-animate="fade-up">
      <span class="section__eyebrow">Testimonials</span>
      <h2 class="display-3">What Our Patients Say</h2>
      <div style="display: flex; align-items: center; justify-content: center; gap: var(--space-sm); margin-top: var(--space-lg);">
        <div style="display: flex; gap: 4px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <span style="font-size: 1.25rem; font-weight: 600; color: var(--color-charcoal);">5.0</span>
        <span style="color: var(--color-gray-medium);">•</span>
        <span style="color: var(--color-gray-dark);">Consistently 5-star rated</span>
      </div>
    </div>

    <div class="testimonials-scroll-container mt-4xl">
      <div class="testimonials-scroll-track">
        <article class="testimonial-card glass">
          <div style="display: flex; gap: 4px; margin-bottom: var(--space-md); color: var(--color-accent);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <p style="font-size: 1.0625rem; line-height: 1.7; margin-bottom: var(--space-lg); color: var(--color-charcoal);">
            "Dr. Beyerl transformed my chronic back pain into a thing of the past. His holistic approach and genuine care made all the difference."
          </p>
          <p style="font-weight: 600; color: var(--color-charcoal);">— Sarah M.</p>
        </article>

        <article class="testimonial-card glass">
          <div style="display: flex; gap: 4px; margin-bottom: var(--space-md); color: var(--color-accent);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <p style="font-size: 1.0625rem; line-height: 1.7; margin-bottom: var(--space-lg); color: var(--color-charcoal);">
            "After years of migraines, I finally found relief. The team here truly cares about their patients and it shows in every visit."
          </p>
          <p style="font-weight: 600; color: var(--color-charcoal);">— Michael T.</p>
        </article>

        <article class="testimonial-card glass">
          <div style="display: flex; gap: 4px; margin-bottom: var(--space-md); color: var(--color-accent);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
