---
/**
 * HeroVideo Component
 * Clean, trust-building hero for a chiropractic practice
 */

interface Props {
  posterImage: string;
  ctaText: string;
  ctaLink: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  posterImage,
  ctaText,
  ctaLink,
  secondaryCtaText,
  secondaryCtaLink,
} = Astro.props;

const videoUrl = 'https://res.cloudinary.com/dku1gnuat/video/upload/v1773678669/copy_C8C8BA7D-35C3-4286-85F6-927425408BE0_q174of.mp4';
---

<section class="hero" aria-label="Hero section">
  <!-- Background Video -->
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    poster={posterImage}
    aria-hidden="true"
  >
    <source src={videoUrl} type="video/mp4" />
  </video>

  <!-- Overlay -->
  <div class="hero__overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero__content">
    <div class="hero__text">
      <span class="hero__eyebrow">The Bridge Chiropractic &middot; San Diego</span>
      <h1 class="hero__title">Move better.<br />Feel stronger.<br />Stay independent.</h1>
      <p class="hero__subtitle">Personalized chiropractic care for active adults who want lasting relief — not quick fixes. Dr. Nate Beyerl helps you reduce pain, restore movement, and build long-term resilience.</p>
      <div class="hero__cta-group">
        <a href={ctaLink} class="btn btn--primary btn--lg">
          {ctaText}
        </a>
        {secondaryCtaText && secondaryCtaLink && (
          <a href={secondaryCtaLink} class="hero__secondary-link">
            {secondaryCtaText}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* Video Background */
  .hero__video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }

  /* Overlay — darker on left for text readability */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.55) 50%,
      rgba(0, 0, 0, 0.35) 100%
    );
    z-index: 1;
  }

  /* Content — left-aligned */
  .hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-2xl);
  }

  .hero__text {
    max-width: 640px;
  }

  /* Eyebrow */
  .hero__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.1s forwards;
  }

  /* Title */
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.25s forwards;
  }

  /* Subtitle */
  .hero__subtitle {
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    font-weight: 400;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-xl);
    max-width: 520px;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.4s forwards;
  }

  /* CTA Group */
  .hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl);
    align-items: center;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.55s forwards;
  }

  .hero__secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero__secondary-link:hover {
    color: var(--color-white);
    gap: 12px;
  }


  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      max-height: none;
      align-items: flex-end;
    }

    .hero__content {
      padding: 0 var(--space-lg) var(--space-5xl);
    }

    .hero__text {
      max-width: 100%;
    }

    .hero__title {
      font-size: clamp(1.875rem, 7vw, 2.5rem);
    }

    .hero__subtitle {
      max-width: 100%;
    }

    .hero__cta-group {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }

    .hero__cta-group .btn {
      width: 100%;
      max-width: 320px;
      text-align: center;
    }

  }

  @media (max-width: 480px) {
    .hero__content {
      padding: 0 var(--space-md) var(--space-4xl);
    }

    .hero__title {
      font-size: clamp(1.75rem, 8vw, 2.25rem);
    }

    .hero__eyebrow {
      font-size: 0.75rem;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow,
    .hero__title,
    .hero__subtitle,
    .hero__cta-group {
      animation: none;
      opacity: 1;
    }

  }

  /* High Contrast */
  @media (prefers-contrast: high) {
    .hero__overlay {
      background: rgba(0, 0, 0, 0.85);
    }
  }
</style>

